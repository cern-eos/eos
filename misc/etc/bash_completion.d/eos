#!/usr/bin/env bash

if [[ -n "${_EOS_BASH_COMPLETION_LOADED:-}" ]]; then
  return 0 2>/dev/null || exit 0
fi
_EOS_BASH_COMPLETION_LOADED=1

_eos_comp()
{
  COMPREPLY=()

  local reply
  while IFS= read -r reply; do
    [[ -z "${reply}" ]] && continue
    [[ ${reply} != "${word}"* ]] && continue
    COMPREPLY+=("${reply}")
  done <<< "$1"

  for reply in "${COMPREPLY[@]}"; do
    if [[ ${reply} == *= || ${reply} == */ ]]; then
      compopt -o nospace -o filenames 2>/dev/null
      break
    fi
  done
}

_eos_dynamic_complete()
{
  local args=()
  local i

  for ((i = 1; i < COMP_CWORD; ++i)); do
    args+=("${COMP_WORDS[i]}")
  done

  args+=("${word}")

  local old_ifs="$IFS"
  IFS=$'\n'
  local opts
  opts=$(eos __complete "${args[@]}" 2>/dev/null)
  IFS="$old_ifs"

  if [[ -n "${opts}" ]]; then
    _eos_comp "${opts}"
  else
    COMPREPLY=()
  fi
}

_eos_find_command_index()
{
  local i token

  for ((i = 1; i < COMP_CWORD; ++i)); do
    token="${COMP_WORDS[i]}"

    case "${token}" in
      -a|--app)
        ((++i))
        continue
        ;;
      -r|--role)
        ((i += 2))
        continue
        ;;
      -b|--batch|-h|--help|-j|--json|-s|-v|--version)
        continue
        ;;
      root://*|ipc://*)
        continue
        ;;
      -*)
        continue
        ;;
      *)
        printf '%s\n' "${i}"
        return 0
        ;;
    esac
  done

  printf '0\n'
}

_eos_path_capable_command()
{
  local command_index command
  command_index=$(_eos_find_command_index)

  if [[ "${command_index}" == "0" ]]; then
    return 1
  fi

  command="${COMP_WORDS[command_index]}"

  case "${command}" in
    acl|attr|cat|cd|chmod|chown|cp|du|file|fileinfo|find|info|ln|ls|mkdir|mv|rm|rmdir|stat|touch)
      return 0
      ;;
  esac

  return 1
}

_eos_local_path_complete()
{
  COMPREPLY=()

  local reply
  while IFS= read -r reply; do
    [[ -z "${reply}" ]] && continue
    COMPREPLY+=("${reply}")
  done < <(compgen -f -- "${word}")

  [[ ${#COMPREPLY[@]} -gt 0 ]] || return 1
  compopt -o filenames 2>/dev/null
  return 0
}

_eos()
{
  COMPREPLY=()
  compopt +o default +o bashdefault 2>/dev/null

  local word="${COMP_WORDS[COMP_CWORD]}"

  if [[ ${word} == ./* || ${word} == ../* || ${word} == ~/* ]]; then
    _eos_local_path_complete && return 0
  fi

  _eos_dynamic_complete

  if [[ ${#COMPREPLY[@]} -eq 0 && ${word} != -* && ${word} != /eos* ]] &&
     _eos_path_capable_command; then
    _eos_local_path_complete && return 0
  fi
}

complete -F _eos eos
