#!/bin/bash

prefix=$1
host=${2-"localhost"}
url=root://$host
EOS_ACCOUNTING_DIR=$prefix

log_section() {
  echo
  echo "=== $* ==="
}

log_step() {
  echo "-- $*"
}

log_ok() {
  echo "OK: $*"
}

log_fail() {
  echo "FAIL: $*"
  exit 1
}

run_timed() {
  description=$1
  shift

  log_step "$description"
  start_time=$(date +%s)
  "$@"
  rc=$?
  end_time=$(date +%s)
  elapsed=$((end_time - start_time))

  if [[ $rc -ne 0 ]];
  then
    log_fail "$description failed with rc=$rc after ${elapsed}s"
  fi

  log_ok "$description completed in ${elapsed}s"
}

cleanup() {
  log_step "Cleaning up $EOS_ACCOUNTING_DIR"
  start_time=$(date +%s)
  output=$(eos rm -rF --no-confirmation $EOS_ACCOUNTING_DIR/ 2>&1)
  rc=$?
  end_time=$(date +%s)
  elapsed=$((end_time - start_time))

  if [[ $rc -ne 0 ]] && ! echo "$output" | grep -q "no such file or directory";
  then
    echo "$output"
    log_fail "Cleaning up $EOS_ACCOUNTING_DIR failed with rc=$rc after ${elapsed}s"
  fi

  log_ok "Cleanup completed in ${elapsed}s"
}

accounting_matches() {
  path=$1
  expected_treecont=$2
  expected_treefiles=$3
  expected_treesize=$4
  verbose=${5:-0}
  fileinfoRes=`eos fileinfo $path -m`
  treecont=`echo $fileinfoRes | grep -o 'treecontainers=[^ ]\+' | cut -d= -f2`
  treefiles=`echo $fileinfoRes | grep -o 'treefiles=[^ ]\+' | cut -d= -f2`
  treesize=`echo $fileinfoRes | grep -o 'treesize=[^ ]\+' | cut -d= -f2`
  error=0
  if [[ ${treecont:--1} -ne $expected_treecont ]];
  then
    if [[ $verbose -eq 1 ]];
    then
      echo "path: "$path " expected $expected_treecont treecontainers, got $treecont"
    fi
    error=1
  fi
  if [[ ${treefiles:--1} -ne $expected_treefiles ]];
  then
    error=1
    if [[ $verbose -eq 1 ]];
    then
      echo "path: "$path " expected $expected_treefiles treefiles, got $treefiles"
    fi
  fi
  if [[ ${treesize:--1} -ne $expected_treesize ]];
  then
    error=1
    if [[ $verbose -eq 1 ]];
    then
      echo "path: "$path " expected $expected_treesize treesize, got $treesize"
    fi
  fi

  return $error
}

# Convenient function to test the accounting variables
test_accounting() {
  accounting_matches "$1" "$2" "$3" "$4" 1

  if [[ $? -eq 0 ]];
  then
    log_ok "$1 accounting matches treecontainers=$2 treefiles=$3 treesize=$4"
    return
  fi

  log_fail "$1 accounting mismatch"
}

wait_accounting() {
  path=$1
  expected_treecont=$2
  expected_treefiles=$3
  expected_treesize=$4
  timeout=${5:-30}
  deadline=$(($(date +%s)+timeout))
  start_time=$(date +%s)

  log_step "Waiting for accounting on $path"

  while [[ $(date +%s) -le $deadline ]];
  do
    if accounting_matches "$path" "$expected_treecont" "$expected_treefiles" "$expected_treesize";
    then
      elapsed=$(($(date +%s)-start_time))
      log_ok "$path accounting matched after ${elapsed}s"
      return
    fi

    sleep 1
  done

  echo "Timed out waiting for accounting on $path"
  test_accounting "$path" "$expected_treecont" "$expected_treefiles" "$expected_treesize"
}

wait_accounting_stable() {
  path=$1
  expected_treecont=$2
  expected_treefiles=$3
  expected_treesize=$4
  stable_for=${5:-6}
  timeout=${6:-30}
  deadline=$(($(date +%s)+timeout))
  stable_start=0
  start_time=$(date +%s)

  log_step "Waiting for stable accounting on $path"

  while [[ $(date +%s) -le $deadline ]];
  do
    if accounting_matches "$path" "$expected_treecont" "$expected_treefiles" "$expected_treesize";
    then
      if [[ $stable_start -eq 0 ]];
      then
        stable_start=$(date +%s)
      fi

      if [[ $(($(date +%s)-stable_start)) -ge $stable_for ]];
      then
        elapsed=$(($(date +%s)-start_time))
        log_ok "$path accounting stayed stable for ${stable_for}s after ${elapsed}s"
        return
      fi
    else
      stable_start=0
    fi

    sleep 1
  done

  echo "Timed out waiting for stable accounting on $path"
  test_accounting "$path" "$expected_treecont" "$expected_treefiles" "$expected_treesize"
}

check_recompute_under_concurrent_modifications() {
  path=$1
  race_dir=$path/recompute-race
  stop_file=$(mktemp /tmp/eos-accounting-race-stop.XXXXXX)
  rm -f "$stop_file"
  mutator_pids=""
  race_dirs=30
  race_base_files=5
  race_mutators=8

  eos mkdir -p "$race_dir"
  for (( i=0; i<$race_dirs; i++ ));
  do
    eos mkdir -p "$race_dir/$i"

    for (( j=0; j<$race_base_files; j++ ));
    do
      eos cp /etc/passwd "$url/$race_dir/$i/base_$j" >/dev/null 2>&1
    done
  done

  for (( i=0; i<$race_mutators; i++ ));
  do
    (
      n=0
      while [[ ! -f "$stop_file" ]];
      do
        eos cp /etc/passwd "$url/$race_dir/$i/race_$n" >/dev/null 2>&1
        n=$((n+1))
      done
    ) &
    mutator_pids="$mutator_pids $!"
  done

  sleep 1
  rc=0
  output=""
  concurrent_warning_seen=0

  for (( attempt=0; attempt<5; attempt++ ));
  do
    output=$(eos ns recompute_tree_size "$path" 2>&1)
    rc=$?

    if echo "$output" | grep -q "concurrent modifications";
    then
      concurrent_warning_seen=1
    fi

    if [[ $rc -ne 0 ]];
    then
      break
    fi

    sleep 1
  done

  touch "$stop_file"

  for pid in $mutator_pids;
  do
    wait "$pid"
  done

  rm -f "$stop_file"
  eos rm -rF --no-confirmation "$race_dir"

  if [[ $rc -eq 0 ]];
  then
    if [[ $concurrent_warning_seen -eq 1 ]];
    then
      log_ok "recompute_tree_size reported concurrent modifications"
      return
    fi

    log_ok "recompute_tree_size completed without observing a dirty recompute window"
    return
  fi

  if ! echo "$output" | grep -q "concurrent modifications";
  then
    echo "Expected recompute_tree_size output to mention concurrent modifications"
    echo "$output"
    log_fail "recompute_tree_size failed without concurrent modification warning"
  fi

  log_ok "recompute_tree_size reported concurrent modifications as expected"
}

expect_concurrent_recompute_busy() {
  path=$1
  output=""
  busy_seen=0

  for (( attempt=0; attempt<10; attempt++ ));
  do
    first_output=$(mktemp /tmp/eos-accounting-recompute.XXXXXX)
    eos ns recompute_tree_size "$path" > "$first_output" 2>&1 &
    first_pid=$!

    for (( probe=0; probe<20; probe++ ));
    do
      if ! kill -0 "$first_pid" 2>/dev/null;
      then
        break
      fi

      output=$(eos ns recompute_tree_size "$path" 2>&1)
      rc=$?

      if [[ $rc -ne 0 ]] &&
         echo "$output" | grep -q "another tree-size recompute is already active";
      then
        busy_seen=1
        break
      fi

      sleep 0.1
    done

    wait "$first_pid"
    rm -f "$first_output"

    if [[ $busy_seen -eq 1 ]];
    then
      log_ok "concurrent recompute_tree_size failed as expected with EBUSY"
      return
    fi
  done

  echo "Expected concurrent recompute_tree_size to fail with EBUSY"
  echo "$output"
  log_fail "concurrent recompute_tree_size did not report active recompute"
}

test_start_time=$(date +%s)

log_section "EOS Accounting Test"
echo "prefix=$prefix"
echo "host=$host"
echo "url=$url"
echo "EOS_ACCOUNTING_DIR=$EOS_ACCOUNTING_DIR"

log_section "Setup"
cleanup

run_timed "Creating test root" eos mkdir -p $EOS_ACCOUNTING_DIR/

test_accounting $EOS_ACCOUNTING_DIR 0 0 0

run_timed "Creating source directory" eos mkdir -p $EOS_ACCOUNTING_DIR/source
run_timed "Creating destination directory" eos mkdir -p $EOS_ACCOUNTING_DIR/destination

nDirs=20
nFiles=10

log_section "Initial Tree Creation"
log_step "Creating $nDirs source directories with $nFiles file pairs each"
start_time=$(date +%s)

# create nDirs directories in each we will create another directory containing a 0-size file (touch)
# then copy /etc/passwd to the nDirs directories
for (( i=0; i<$nDirs; i++ ));
do
  eos mkdir -p $EOS_ACCOUNTING_DIR/source/$i &
done
wait
for (( i=0; i<$nDirs; i++ ));
do
  for (( j=0; j<$nFiles; j++));
  do
    eos mkdir -p $EOS_ACCOUNTING_DIR/source/$i/dir$j && eos touch $EOS_ACCOUNTING_DIR/source/$i/dir$j/touch$j &
    eos cp /etc/passwd $url/$EOS_ACCOUNTING_DIR/source/$i/passwd$j &
  done
  wait
done

end_time=$(date +%s)
elapsed=$((end_time - start_time))
log_ok "Created initial tree in ${elapsed}s"

totalNbFiles=$((2*nFiles*nDirs))
passwdFileSize=`stat -c%s /etc/passwd`
# Only size of passwd files (not the touched files!)
totalTreeSize=$(($nDirs*$nFiles*passwdFileSize))

wait_accounting $EOS_ACCOUNTING_DIR $((nDirs+(nFiles*nDirs)+2)) $totalNbFiles $totalTreeSize
wait_accounting $EOS_ACCOUNTING_DIR/source $((nDirs+(nFiles*nDirs))) $totalNbFiles $totalTreeSize

log_section "Initial Accounting Validation"
# Directory located in EOS_ACCOUNTING_DIR should have source+destination+all sources sub directories created above,
# all the files and a tree size of all passwd files
test_accounting $EOS_ACCOUNTING_DIR $((nDirs+(nFiles*nDirs)+2)) $totalNbFiles $totalTreeSize
# Source directory should have all directories created in the for loop above, all the files
# and all the tree size of all passwd files
test_accounting $EOS_ACCOUNTING_DIR/source $((nDirs+(nFiles*nDirs))) $totalNbFiles $totalTreeSize
# Destination has nothing in it
test_accounting $EOS_ACCOUNTING_DIR/destination 0 0 0

log_section "Concurrent Recompute Exclusion"
log_step "Checking a second recompute_tree_size fails while another is active"
expect_concurrent_recompute_busy "$EOS_ACCOUNTING_DIR"

# Perform a parallel directory move from source to destination
log_section "Move Accounting"
log_step "Moving source children to destination in parallel"
start_time=$(date +%s)
for (( i=0; i<$nDirs; i++ ));
do
  eos mv $EOS_ACCOUNTING_DIR/source/$i $EOS_ACCOUNTING_DIR/destination/$i &
done
wait
end_time=$(date +%s)
elapsed=$((end_time - start_time))
log_ok "Parallel move completed in ${elapsed}s"

wait_accounting $EOS_ACCOUNTING_DIR $((nDirs+(nFiles*nDirs)+2)) $totalNbFiles $totalTreeSize
wait_accounting $EOS_ACCOUNTING_DIR/source 0 0 0
wait_accounting $EOS_ACCOUNTING_DIR/destination $((nDirs+(nFiles*nDirs))) $totalNbFiles $totalTreeSize

log_section "Move Accounting Validation"
# EOS_ACCOUNTING_DIR's accounting should be the same as previously
test_accounting $EOS_ACCOUNTING_DIR $((nDirs+(nFiles*nDirs)+2)) $totalNbFiles $totalTreeSize

# Source should have all counters updated to 0
test_accounting $EOS_ACCOUNTING_DIR/source 0 0 0
# Destination should have the same accounting as the source one previously
test_accounting $EOS_ACCOUNTING_DIR/destination $((nDirs+(nFiles*nDirs))) $totalNbFiles $totalTreeSize

# Perform the deletion of half of the directories created in the destination
log_section "Deletion And Recompute"
log_step "Deleting half of the destination directories"
start_time=$(date +%s)
for (( i=0; i<$nDirs; i+=2 ));
do
  eos rm -rF --no-confirmation $EOS_ACCOUNTING_DIR/destination/$i &
done
wait
end_time=$(date +%s)
elapsed=$((end_time - start_time))
log_ok "Parallel deletion completed in ${elapsed}s"

# Then move the destination directory
run_timed "Moving destination back under source" \
  eos mv $EOS_ACCOUNTING_DIR/destination/ $EOS_ACCOUNTING_DIR/source

# Check the recompute_tree_size (we did not give the time for the accounting thread to do its job)
run_timed "Running recompute_tree_size before accounting catches up" \
  eos ns recompute_tree_size $EOS_ACCOUNTING_DIR/

log_section "Recompute Race Behavior"
log_step "Running recompute_tree_size while modifications happen inside the recomputed subtree"
check_recompute_under_concurrent_modifications "$EOS_ACCOUNTING_DIR"

log_section "Final Recompute Validation"
run_timed "Running clean recompute_tree_size after concurrent modification check" \
  eos ns recompute_tree_size $EOS_ACCOUNTING_DIR/

# Source directory has now the destination directory + all directories under it that got divided by two by the previous deletion
wait_accounting_stable $EOS_ACCOUNTING_DIR/source $(((nDirs+(nFiles*nDirs))/2+1)) $((totalNbFiles/2)) $((totalTreeSize/2))

log_section "Cleanup"
cleanup

test_end_time=$(date +%s)
test_elapsed=$((test_end_time - test_start_time))
log_ok "EOS accounting test completed in ${test_elapsed}s"
exit 0
