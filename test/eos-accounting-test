#!/bin/bash

prefix=$1
host=${2-"localhost"}
url=root://$host
EOS_ACCOUNTING_DIR=$prefix

log() {
  echo "[eos-accounting-test] $*"
}

section() {
  echo
  log "== $* =="
}

pass() {
  log "PASS: $*"
}

fail() {
  log "FAIL: $*"
  exit 1
}

run_quiet() {
  local context=$1
  shift
  local output
  local rc

  output=$("$@" 2>&1)
  rc=$?

  if [[ $rc -ne 0 ]];
  then
    if [[ -n "$output" ]];
    then
      echo "$output"
    fi

    fail "$context"
  fi
}

wait_all() {
  local context=$1
  shift
  local pid
  local failure=0

  for pid in "$@";
  do
    wait "$pid" || failure=1
  done

  if [[ $failure -ne 0 ]];
  then
    fail "$context"
  fi
}

elapsed_since() {
  local start_time=$1
  local end_time
  end_time=$(date +%s)
  echo $((end_time - start_time))
}

status_field() {
  local status_line=$1
  local key=$2
  echo "$status_line" | tr ' ' '\n' | sed -n "s/^${key}=//p" | tail -n1
}

assert_status_field_eq() {
  local status_output=$1
  local key=$2
  local expected=$3
  local context=$4
  local value
  value=$(status_field "$status_output" "$key")

  if [[ "$value" != "$expected" ]];
  then
    echo "$status_output"
    fail "$context: expected $key=$expected, got ${value:-missing}"
  fi
}

assert_status_field_positive() {
  local status_output=$1
  local key=$2
  local context=$3
  local value
  value=$(status_field "$status_output" "$key")

  if [[ -z "$value" || ! "$value" =~ ^[0-9]+$ || "$value" -le 0 ]];
  then
    echo "$status_output"
    fail "$context: expected positive $key, got ${value:-missing}"
  fi
}

assert_recompute_status_success() {
  local context=$1
  local status_output
  local status_rc

  status_output=$(eos ns recompute_tree_size --status 2>&1)
  status_rc=$?

  if [[ $status_rc -ne 0 ]];
  then
    echo "$status_output"
    fail "$context: failed to query recompute_tree_size --status"
  fi

  assert_status_field_eq "$status_output" "state" "completed" "$context status"
  assert_status_field_eq "$status_output" "retc" "0" "$context status"
  assert_status_field_eq "$status_output" "result" "success" "$context status"
  assert_status_field_eq "$status_output" "available" "1" "$context status"
  assert_status_field_eq "$status_output" "converged" "1" "$context status"
  assert_status_field_eq "$status_output" "publishable" "1" "$context status"
  assert_status_field_eq "$status_output" "retry_required" "0" "$context status"
  assert_status_field_eq "$status_output" "retry_candidates" "0" "$context status"
  assert_status_field_eq "$status_output" "missing_targets" "0" "$context status"
  assert_status_field_eq "$status_output" "write_failed_targets" "0" "$context status"
  assert_status_field_eq "$status_output" "failed_containers" "0" "$context status"
  assert_status_field_eq "$status_output" "publish_apply_status" "0" "$context status"
  assert_status_field_eq "$status_output" "fence_acquired" "1" "$context status"
  assert_status_field_positive "$status_output" "snapshot_containers" "$context status"
  assert_status_field_positive "$status_output" "publish_targets" "$context status"
  pass "$context: recompute --status reports a successful published run"
}

wait_for_live_accounting() {
  local reason=$1
  log "Waiting 10 seconds for live accounting to settle after $reason"
  sleep 10
}

section "Configuration"
log "prefix: $prefix"
log "host: $host"
log "url: $url"
log "accounting directory: $EOS_ACCOUNTING_DIR"

if [[ -z "$EOS_ACCOUNTING_DIR" ]];
then
  fail "usage: $0 <eos-accounting-dir> [host]"
fi

cleanup() {
  local start_time
  start_time=$(date +%s)
  log "Cleaning up $EOS_ACCOUNTING_DIR"
  eos rm -rF --no-confirmation "$EOS_ACCOUNTING_DIR/" || true

  if eos fileinfo "$EOS_ACCOUNTING_DIR/" >/dev/null 2>&1;
  then
    fail "cleanup failed: $EOS_ACCOUNTING_DIR still exists"
  fi

  pass "cleanup completed in $(elapsed_since "$start_time") seconds"
}

# Convenient function to test the accounting variables
test_accounting() {
  local path=$1
  local expected_treecont=$2
  local expected_treefiles=$3
  local expected_treesize=$4
  local fileinfoRes
  local treecont
  local treefiles
  local treesize
  local error=0

  fileinfoRes=$(eos fileinfo "$path" -m) || fail "failed to read fileinfo for $path"
  treecont=$(echo "$fileinfoRes" | grep -o 'treecontainers=[^ ]\+' | cut -d= -f2)
  treefiles=$(echo "$fileinfoRes" | grep -o 'treefiles=[^ ]\+' | cut -d= -f2)
  treesize=$(echo "$fileinfoRes" | grep -o 'treesize=[^ ]\+' | cut -d= -f2)

  if [[ -z "$treecont" || -z "$treefiles" || -z "$treesize" ]];
  then
    echo "$fileinfoRes"
    fail "failed to parse tree accounting fields for $path"
  fi

  if [[ $treecont -ne $expected_treecont ]];
  then
    log "$path: expected treecontainers=$expected_treecont, got $treecont"
    error=1
  fi
  if [[ $treefiles -ne $expected_treefiles ]];
  then
    error=1
    log "$path: expected treefiles=$expected_treefiles, got $treefiles"
  fi
  if [[ $treesize -ne $expected_treesize ]];
  then
    error=1
    log "$path: expected treesize=$expected_treesize, got $treesize"
  fi
  if [[ $error -eq 1 ]];
  then
    echo "$fileinfoRes"
    fail "accounting mismatch for $path"
  fi

  pass "$path: treecontainers=$treecont treefiles=$treefiles treesize=$treesize"
}

RECOMPUTE_TREE_SIZE_TIMEOUT=${EOS_ACCOUNTING_RECOMPUTE_TIMEOUT:-300}
RECOMPUTE_TREE_SIZE_POLL_INTERVAL=${EOS_ACCOUNTING_RECOMPUTE_POLL_INTERVAL:-1}

wait_recompute_tree_size_status() {
  local accepted_live_retry=$1
  local start_time
  local status_output
  local status_rc
  local status_state
  local status_retc
  local elapsed
  start_time=$(date +%s)

  while true;
  do
    status_output=$(eos ns recompute_tree_size --status 2>&1)
    status_rc=$?

    if [[ $status_rc -ne 0 ]];
    then
      echo "$status_output"
      log "Failed to query recompute_tree_size status"
      return $status_rc
    fi

    status_state=$(status_field "$status_output" "state")
    status_retc=$(status_field "$status_output" "retc")

    if [[ "$status_state" == "completed" ]];
    then
      if [[ "${status_retc:-1}" == "0" ]];
      then
        log "Recompute status: $status_output"
        return 0
      fi

      echo "$status_output"
      log "recompute_tree_size completed with retc=${status_retc:-unknown}"
      return 1
    fi

    if [[ "$status_state" == "failed" ]];
    then
      local retry_reason
      retry_reason=$(status_field "$status_output" "retry_reason")

      if [[ $accepted_live_retry -eq 1 &&
            ( -n "$retry_reason" ||
              "$status_output" == *"requires retry"* ||
              "$status_output" == *"could not acquire publish fence"* ||
              "$status_output" == *"unsequenced covered updates"* ||
              "$status_output" == *"already active"* ) ]];
      then
        return 0
      fi

      echo "$status_output"
      log "recompute_tree_size failed"
      return 1
    fi

    if [[ "$status_state" == "stopped" ]];
    then
      echo "$status_output"
      log "recompute_tree_size stopped"
      return 1
    fi

    elapsed=$(elapsed_since "$start_time")

    if [[ $elapsed -gt $RECOMPUTE_TREE_SIZE_TIMEOUT ]];
    then
      echo "$status_output"
      log "Timed out waiting for recompute_tree_size status"
      return 1
    fi

    sleep $RECOMPUTE_TREE_SIZE_POLL_INTERVAL
  done
}

numeric_status_field() {
  local status_line=$1
  local key=$2
  local value
  value=$(status_field "$status_line" "$key")

  if [[ "$value" =~ ^[0-9]+$ ]];
  then
    echo "$value"
  else
    echo 0
  fi
}

recompute_tree_size_and_wait() {
  local path=$1
  local context=${2:-$path}
  local start_time
  local recompute_output
  local recompute_rc
  local elapsed
  log "$context: submitting tree-size recompute for $path"
  start_time=$(date +%s)

  while true;
  do
    recompute_output=$(eos ns recompute_tree_size "$path" 2>&1)
    recompute_rc=$?

    if [[ $recompute_rc -eq 0 ]];
    then
      wait_recompute_tree_size_status 0 || return 1
      elapsed=$(elapsed_since "$start_time")
      pass "$context: recompute completed in $elapsed seconds"
      assert_recompute_status_success "$context"
      return 0
    fi

    if [[ "$recompute_output" != *"already active"* ]];
    then
      echo "$recompute_output"
      log "Failed to submit recompute_tree_size for $path"
      return $recompute_rc
    fi

    log "$context: another recompute is active, waiting before retrying"
    wait_recompute_tree_size_status 1 || return 1
    elapsed=$(elapsed_since "$start_time")

    if [[ $elapsed -gt $RECOMPUTE_TREE_SIZE_TIMEOUT ]];
    then
      log "Timed out waiting to submit recompute_tree_size for $path"
      return 1
    fi
  done
}

wait_retry_moved_items() {
  local moved_file=$1
  local min_count=$2
  local context=$3
  local max_polls=${4:-250}
  local moved_count

  for (( poll=0; poll<$max_polls; poll++ ));
  do
    moved_count=$(wc -l < "$moved_file" | tr -d ' ')

    if [[ ${moved_count:-0} -ge $min_count ]];
    then
      log "$context: observed $moved_count moved retry-validation items"
      return 0
    fi

    sleep 0.02
  done

  log "$context: timed out waiting for retry-validation traffic"
  return 1
}

wait_recompute_retry_observed() {
  local context=$1
  local max_polls=${2:-250}
  local status_output
  local status_rc
  local status_state
  local status_retc
  local retry_passes
  local retry_candidates
  local retry_reason

  for (( poll=0; poll<$max_polls; poll++ ));
  do
    status_output=$(eos ns recompute_tree_size --status 2>&1)
    status_rc=$?

    if [[ $status_rc -ne 0 ]];
    then
      echo "$status_output"
      return $status_rc
    fi

    status_state=$(status_field "$status_output" "state")
    status_retc=$(status_field "$status_output" "retc")
    retry_passes=$(numeric_status_field "$status_output" "retry_passes")
    retry_candidates=$(numeric_status_field "$status_output" "retry_candidates")
    retry_reason=$(status_field "$status_output" "retry_reason")

    if [[ $retry_passes -gt 0 || $retry_candidates -gt 0 ||
          -n "$retry_reason" ]];
    then
      log "$context: observed retry state: $status_output"
      return 0
    fi

    if [[ "$status_state" == "completed" ]];
    then
      echo "$status_output"
      if [[ "${status_retc:-1}" == "0" ]];
      then
        log "$context: recompute completed without retry"
      fi
      return 1
    fi

    if [[ "$status_state" == "failed" || "$status_state" == "stopped" ]];
    then
      echo "$status_output"
      return 1
    fi

    sleep 0.02
  done

  log "$context: timed out waiting for recompute retry"
  return 1
}

wait_recompute_success_after_retry() {
  local context=$1
  local max_polls=${2:-500}
  local status_output
  local status_rc
  local status_state
  local status_retc
  local status_result
  local converged
  local retry_passes
  local retry_limit_reached

  for (( poll=0; poll<$max_polls; poll++ ));
  do
    status_output=$(eos ns recompute_tree_size --status 2>&1)
    status_rc=$?

    if [[ $status_rc -ne 0 ]];
    then
      echo "$status_output"
      return $status_rc
    fi

    status_state=$(status_field "$status_output" "state")

    if [[ "$status_state" == "completed" ]];
    then
      status_retc=$(status_field "$status_output" "retc")
      status_result=$(status_field "$status_output" "result")
      converged=$(numeric_status_field "$status_output" "converged")
      retry_passes=$(numeric_status_field "$status_output" "retry_passes")
      retry_limit_reached=$(numeric_status_field "$status_output" \
        "retry_limit_reached")

      if [[ "${status_retc:-1}" == "0" && "$status_result" == "success" &&
            $converged -eq 1 && $retry_passes -ge 1 &&
            $retry_passes -le 3 && $retry_limit_reached -eq 0 ]];
      then
        log "$context: final recompute status: $status_output"
        return 0
      fi

      echo "$status_output"
      fail "$context: expected successful converged recompute after 1-3 retries"
    fi

    if [[ "$status_state" == "failed" || "$status_state" == "stopped" ]];
    then
      echo "$status_output"
      return 1
    fi

    sleep 0.05
  done

  log "$context: timed out waiting for recompute completion"
  return 1
}

test_start_time=$(date +%s)

section "Clean test area"
cleanup

section "Create initial source and destination tree"
run_quiet "failed to create $EOS_ACCOUNTING_DIR" \
  eos mkdir -p "$EOS_ACCOUNTING_DIR/"

test_accounting "$EOS_ACCOUNTING_DIR" 0 0 0

run_quiet "failed to create source directory" \
  eos mkdir -p "$EOS_ACCOUNTING_DIR/source"
run_quiet "failed to create destination directory" \
  eos mkdir -p "$EOS_ACCOUNTING_DIR/destination"

nDirs=20
nFiles=10

start_time=$(date +%s)
log "Creating $nDirs source directories with $nFiles file pairs each"

# create nDirs directories in each we will create another directory containing a 0-size file (touch)
# then copy /etc/passwd to the nDirs directories
initial_dir_pids=()
for (( i=0; i<$nDirs; i++ ));
do
  run_quiet "failed to create source child $i" \
    eos mkdir -p $EOS_ACCOUNTING_DIR/source/$i &
  initial_dir_pids+=($!)
done
wait_all "failed to create one or more source children" "${initial_dir_pids[@]}"
for (( i=0; i<$nDirs; i++ ));
do
  initial_file_pids=()
  for (( j=0; j<$nFiles; j++));
  do
    (
      run_quiet "failed to create source child $i/dir$j" \
        eos mkdir -p $EOS_ACCOUNTING_DIR/source/$i/dir$j
      run_quiet "failed to touch source child $i/dir$j/touch$j" \
        eos touch $EOS_ACCOUNTING_DIR/source/$i/dir$j/touch$j
    ) &
    initial_file_pids+=($!)
    run_quiet "failed to copy source child $i/passwd$j" \
      eos cp /etc/passwd $url/$EOS_ACCOUNTING_DIR/source/$i/passwd$j &
    initial_file_pids+=($!)
  done
  wait_all "failed to create one or more files under source child $i" \
    "${initial_file_pids[@]}"
done

end_time=$(date +%s)
elapsed=$((end_time - start_time))
pass "Initial tree created in $elapsed seconds"
wait_for_live_accounting "initial tree creation"

totalNbFiles=$((2*nFiles*nDirs))
passwdFileSize=`stat -c%s /etc/passwd`
# Only size of passwd files (not the touched files!)
totalTreeSize=$(($nDirs*$nFiles*passwdFileSize))

section "Validate live accounting after initial creation"
# Directory located in EOS_ACCOUNTING_DIR should have source+destination+all sources sub directories created above,
# all the files and a tree size of all passwd files
test_accounting "$EOS_ACCOUNTING_DIR" $((nDirs+(nFiles*nDirs)+2)) $totalNbFiles $totalTreeSize
# Source directory should have all directories created in the for loop above, all the files
# and all the tree size of all passwd files
test_accounting "$EOS_ACCOUNTING_DIR/source" $((nDirs+(nFiles*nDirs))) $totalNbFiles $totalTreeSize
# Destination has nothing in it
test_accounting "$EOS_ACCOUNTING_DIR/destination" 0 0 0

# Perform a parallel directory move from source to destination
section "Move source children to destination in parallel"
log "Moving $nDirs directories from source to destination"
start_time=$(date +%s)
move_pids=()
for (( i=0; i<$nDirs; i++ ));
do
  run_quiet "failed to move source child $i to destination" \
    eos mv $EOS_ACCOUNTING_DIR/source/$i $EOS_ACCOUNTING_DIR/destination/$i &
  move_pids+=($!)
done
wait_all "failed to move one or more source children to destination" \
  "${move_pids[@]}"
end_time=$(date +%s)
elapsed=$((end_time - start_time))
pass "Parallel directory move completed in $elapsed seconds"

wait_for_live_accounting "parallel directory move"

section "Validate live accounting after parallel move"
# EOS_ACCOUNTING_DIR's accounting should be the same as previously
test_accounting "$EOS_ACCOUNTING_DIR" $((nDirs+(nFiles*nDirs)+2)) $totalNbFiles $totalTreeSize

# Source should have all counters updated to 0
test_accounting "$EOS_ACCOUNTING_DIR/source" 0 0 0
# Destination should have the same accounting as the source one previously
test_accounting "$EOS_ACCOUNTING_DIR/destination" $((nDirs+(nFiles*nDirs))) $totalNbFiles $totalTreeSize

# Perform the deletion of half of the directories created in the destination
section "Delete half of destination and recompute immediately"
log "Deleting every second destination child, then moving destination back to source"
start_time=$(date +%s)
delete_pids=()
for (( i=0; i<$nDirs; i+=2 ));
do
  run_quiet "failed to delete destination child $i" \
    eos rm -rF --no-confirmation $EOS_ACCOUNTING_DIR/destination/$i &
  delete_pids+=($!)
done
wait_all "failed to delete one or more destination children" \
  "${delete_pids[@]}"
end_time=$(date +%s)
elapsed=$((end_time - start_time))
pass "Parallel deletion completed in $elapsed seconds"

# Then move the destination directory
start_time=$(date +%s)
run_quiet "failed to move destination back to source" \
  eos mv $EOS_ACCOUNTING_DIR/destination/ $EOS_ACCOUNTING_DIR/source
end_time=$(date +%s)
elapsed=$((end_time - start_time))
pass "Destination moved back to source in $elapsed seconds"

# Check the recompute_tree_size (we did not give the time for the accounting thread to do its job)
recompute_tree_size_and_wait "$EOS_ACCOUNTING_DIR/" \
  "root recompute after delete-and-move" ||
  fail "root recompute after delete-and-move failed"

section "Validate recomputed accounting after delete-and-move"
# Source directory has now the destination directory + all directories under it that got divided by two by the previous deletion
test_accounting "$EOS_ACCOUNTING_DIR/source" $(((nDirs+(nFiles*nDirs))/2+1)) $((totalNbFiles/2)) $((totalTreeSize/2))

RETRY_VALIDATION_DIR=$EOS_ACCOUNTING_DIR/retry_validation
RETRY_VALIDATION_ROOT=$RETRY_VALIDATION_DIR/root
RETRY_VALIDATION_STAGE=$RETRY_VALIDATION_DIR/staging
nRetryStaticDirs=${EOS_ACCOUNTING_RETRY_STATIC_DIRS:-384}
nRetryStaticTouchFiles=${EOS_ACCOUNTING_RETRY_TOUCH_FILES_PER_DIR:-32}
nRetryMaxMoves=${EOS_ACCOUNTING_RETRY_MOVES:-32}

section "Create retry validation workload"
log "Creating $nRetryStaticDirs static directories with $nRetryStaticTouchFiles zero-size files each under $RETRY_VALIDATION_ROOT"
run_quiet "failed to create retry validation static root" \
  eos mkdir -p $RETRY_VALIDATION_ROOT/static
run_quiet "failed to create retry validation live root" \
  eos mkdir -p $RETRY_VALIDATION_ROOT/live
run_quiet "failed to create retry validation staging root" \
  eos mkdir -p $RETRY_VALIDATION_STAGE
start_time=$(date +%s)
retry_static_pids=()
for (( i=0; i<$nRetryStaticDirs; i++ ));
do
  static_dir=$RETRY_VALIDATION_ROOT/static/dir_$i
  (
    run_quiet "retry static $i: failed to create directory" \
      eos mkdir -p $static_dir

    for (( j=0; j<$nRetryStaticTouchFiles; j++ ));
    do
      run_quiet "retry static $i: failed to touch file $j" \
        eos touch $static_dir/touch_$j
    done

    run_quiet "retry static $i: failed to copy file" \
      eos cp /etc/passwd $url/$static_dir/passwd_$i
  ) &
  retry_static_pids+=($!)
done
retry_static_failure=0
for pid in "${retry_static_pids[@]}";
do
  wait $pid || retry_static_failure=1
done

if [[ $retry_static_failure -ne 0 ]];
then
  fail "retry validation static workload failed"
fi
pass "Retry validation static workload created in $(elapsed_since "$start_time") seconds"
wait_for_live_accounting "retry validation static workload"

create_retry_move_item() {
  local item=$1
  local item_dir=$RETRY_VALIDATION_STAGE/item_$item

  run_quiet "retry item $item: failed to create payload_a" \
    eos mkdir -p $item_dir/payload_a
  run_quiet "retry item $item: failed to create payload_b" \
    eos mkdir -p $item_dir/payload_b
  run_quiet "retry item $item: failed to touch direct file" \
    eos touch $item_dir/touch_$item
  run_quiet "retry item $item: failed to copy direct file" \
    eos cp /etc/passwd $url/$item_dir/passwd_$item
  run_quiet "retry item $item: failed to rename direct file" \
    eos mv $item_dir/passwd_$item $item_dir/passwd_${item}.moved
  run_quiet "retry item $item: failed to touch nested file" \
    eos touch $item_dir/payload_a/nested_touch_$item
  run_quiet "retry item $item: failed to copy nested file" \
    eos cp /etc/passwd $url/$item_dir/payload_b/nested_passwd_$item
}

section "Run single recompute while mutation continues"
retry_stop_file=$(mktemp)
rm -f $retry_stop_file
retry_moved_file=$(mktemp)
: > "$retry_moved_file"

# Item 0 is staged before recompute starts, so the mutator can attach a subtree
# immediately after discovery has moved into snapshotting.
create_retry_move_item 0

run_quiet "failed to drop namespace cache before retry validation recompute" \
  eos ns cache drop

(
  for (( item=0; item<$nRetryMaxMoves; item++ ));
  do
    if [[ -f $retry_stop_file ]];
    then
      break
    fi

    if [[ $item -ne 0 ]];
    then
      create_retry_move_item $item
    fi

    run_quiet "retry item $item: failed to attach subtree" \
      eos mv $RETRY_VALIDATION_STAGE/item_$item \
        $RETRY_VALIDATION_ROOT/live/item_$item
    echo "$item" >> "$retry_moved_file"
    sleep 0.05
  done
) &
retry_activity_pid=$!

if ! wait_retry_moved_items "$retry_moved_file" 1 \
  "single recompute retry mutator";
then
  touch $retry_stop_file
  wait $retry_activity_pid || true
  fail "retry validation mutation workload did not start"
fi

start_time=$(date +%s)
log "Submitting one recompute_tree_size for $RETRY_VALIDATION_ROOT while mutation runs"
retry_recompute_output=$(eos ns recompute_tree_size "$RETRY_VALIDATION_ROOT/" 2>&1)
retry_recompute_rc=$?

if [[ $retry_recompute_rc -ne 0 ]];
then
  touch $retry_stop_file
  wait $retry_activity_pid || true
  echo "$retry_recompute_output"
  fail "single retry recompute submission failed"
fi

if ! wait_recompute_retry_observed "single recompute under mutation";
then
  touch $retry_stop_file
  wait $retry_activity_pid || true
  fail "single recompute did not report retry while mutation was active"
fi

touch $retry_stop_file
wait $retry_activity_pid ||
  fail "retry validation mutation workload failed"
rm -f $retry_stop_file

wait_recompute_success_after_retry "single recompute after mutation stopped" ||
  fail "single recompute did not converge after retry"
pass "Single recompute converged after automatic retry in $(elapsed_since "$start_time") seconds"

retryMovedItems=$(wc -l < "$retry_moved_file" | tr -d ' ')
rm -f "$retry_moved_file"
wait_for_live_accounting "single recompute retry workload"

expectedRetryTreeContainers=$((2+nRetryStaticDirs+(retryMovedItems*3)))
expectedRetryTreeFiles=$(((nRetryStaticDirs*(nRetryStaticTouchFiles+1))+(retryMovedItems*4)))
