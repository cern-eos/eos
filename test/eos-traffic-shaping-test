# ---------------------------------------------------------
# Test: Write Limit Does Not Throttle Reads
# ---------------------------------------------------------
WRITE_ONLY_APP="write-only-limit-app"
echo ""
echo "--- Testing Write Limit Does Not Throttle Reads ---"

xrdcp -f ${TEST_FILE_10MB} "${DEST_URL}/write_only_read_source.dat?eos.app=${WRITE_ONLY_APP}" > /dev/null 2>&1

echo "Priming write feedback loop..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/write_only_prime.dat?eos.app=${WRITE_ONLY_APP}" > /dev/null 2>&1

echo "Creating active write delay for ${WRITE_ONLY_APP}..."
eos io shaping policy set --app ${WRITE_ONLY_APP} --limit-write 1M
sleep 3
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/write_only_active.dat?eos.app=${WRITE_ONLY_APP}" > /dev/null 2>&1 &
PID_WO_W=$!

echo "Waiting 22 seconds for write throttle stabilization..."
sleep 22

START_MS=$(date +%s%3N)
xrdcp -f "${DEST_URL}/write_only_read_source.dat?eos.app=${WRITE_ONLY_APP}" /dev/null > /dev/null 2>&1
READ_RC=$?
END_MS=$(date +%s%3N)

kill -9 $PID_WO_W 2>/dev/null; wait $PID_WO_W 2>/dev/null || true
eos io shaping policy rm --app ${WRITE_ONLY_APP}

READ_DURATION_MS=$((END_MS - START_MS))

if [[ $READ_RC -eq 0 && $READ_DURATION_MS -lt 8000 ]]; then
  echo "✅ Success: Write-only limit did not throttle read transfer (${READ_DURATION_MS} ms)."
else
  echo "❌ Error: Read transfer was unexpectedly slow or failed under write-only limit (rc=${READ_RC}, duration=${READ_DURATION_MS} ms)."
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: Policy Enable / Disable Toggle
# ---------------------------------------------------------
