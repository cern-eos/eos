#!/bin/bash
# ----------------------------------------------------------------------
# File: eos-traffic-shaping-test
# Author: Luis Antonio Obis Aparicio - CERN
# ----------------------------------------------------------------------

if [[ $# -ne 2 ]]; then
  echo "Error: Missing arguments."
  echo "Usage:    $0 <eos_mgm_hostname> <eos_instance_name>"
  echo "Examples:"
  echo "  $0 example.cern.ch example"
  echo "  $0 localhost dev"
  exit 1
fi

EOS_MGM_HOSTNAME=$1
EOS_INSTANCE_NAME=$2
FAILURES=0

echo "Configuring MGM Host: $EOS_MGM_HOSTNAME"
echo "Instance Name: $EOS_INSTANCE_NAME"

if ! command -v jq &> /dev/null; then
  echo "Error: 'jq' is required but not installed."
  exit 1
fi

export XrdSecPROTOCOL=sss

# Enable traffic shaping
eos io shaping enable

eos io shaping config set --estimators-period 100 --report-period 100 --policy-period 100 --system-window 15
eos io shaping config set --detail aggregate
sleep 8

echo "Creating dummy files (10MB and 200MB)..."
TEST_FILE_10MB=/tmp/10mb.dat
dd if=/dev/urandom of=${TEST_FILE_10MB} bs=1M count=10 iflag=fullblock &> /dev/null

TEST_FILE_200MB=/tmp/200mb_throttle.dat
dd if=/dev/urandom of=${TEST_FILE_200MB} bs=1M count=200 iflag=fullblock &> /dev/null

DEST_URL="root://${EOS_MGM_HOSTNAME}//eos/${EOS_INSTANCE_NAME}/traffic_shaping"

eos mkdir -p /eos/${EOS_INSTANCE_NAME}/traffic_shaping/
eos chmod 2777 /eos/${EOS_INSTANCE_NAME}/
eos chmod 2777 /eos/${EOS_INSTANCE_NAME}/traffic_shaping/

# ±20% lower, ±35% upper for 1 MB/s target
LOWER_BOUND=800000
UPPER_BOUND=1350000
WRITE_10MB_LOWER_MS=8000
WRITE_10MB_UPPER_MS=22000
READ_10MB_LOWER_MS=10000
READ_10MB_UPPER_MS=30000

measure_transfer_ms() {
  local src=$1
  local dst=$2
  local start_ms
  local end_ms
  start_ms=$(date +%s%3N)
  xrdcp -f "$src" "$dst" > /dev/null 2>&1
  end_ms=$(date +%s%3N)
  echo $((end_ms - start_ms))
}

wait_for_rate_in_range() {
  local entity_id=$1
  local rate_field=$2
  local lower_bound=$3
  local upper_bound=$4
  shift 4

  JSON_RESULT="[]"
  RATE=0

  for _ in {1..16}; do
    sleep 2
    JSON_RESULT=$(eos io shaping ls --window 5 "$@" --json)
    RATE=$(echo "$JSON_RESULT" | jq -r --arg id "$entity_id" --arg field "$rate_field" 'map(select(.id == $id) | .[$field]) | max // 0')

    if (( $(echo "$RATE > $lower_bound" | bc -l) )) && (( $(echo "$RATE < $upper_bound" | bc -l) )); then
      return 0
    fi
  done

  return 1
}

# ---------------------------------------------------------
# Test: Baseline System and Reporting Engine
# ---------------------------------------------------------
echo ""
echo "--- Testing Baseline System and Reporting Engine ---"
xrdcp ${TEST_FILE_10MB} "${DEST_URL}/10mb.dat?eos.app=traffic-shaping-test-app" -f > /dev/null
sleep 1

JSON_RESULT=$(eos io shaping ls --window 15 --sys --json)
USER_JSON_RESULT=$(eos io shaping ls --window 15 --users --json)
USER_JSON_RESOLVED_RESULT=$(eos io shaping ls --window 15 --users --json --resolve-ids)

if echo "$JSON_RESULT" | jq -e '.[] | select(.id == "traffic-shaping-test-app") | (.write_rate_bps > 0)' > /dev/null; then
  echo "✅ Success: Baseline traffic detected."
else
  echo "❌ Error: Baseline traffic missing."
  echo "Debug Info: $JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

if echo "$USER_JSON_RESULT" | jq -e '.[] | select(.type == "uid" and (.write_rate_bps > 0)) | has("name") | not' > /dev/null && \
   echo "$USER_JSON_RESOLVED_RESULT" | jq -e '.[] | select(.type == "uid" and (.write_rate_bps > 0) and (.name | type == "string" and length > 0))' > /dev/null; then
  echo "✅ Success: UID/GID name resolution is disabled by default in JSON and enabled on request."
else
  echo "❌ Error: UID/GID name resolution JSON defaults are not as expected."
  echo "Debug Info (--users --json): $USER_JSON_RESULT"
  echo "Debug Info (--users --json --resolve-ids): $USER_JSON_RESOLVED_RESULT"
  FAILURES=$((FAILURES + 1))
fi

CONFIG_RESULT=$(eos io shaping config ls)
CONFIG_JSON_RESULT=$(eos io shaping config ls --json)
POLICY_JSON_RESULT=$(eos io shaping policy ls --json)

if echo "$CONFIG_RESULT" | grep -Eq 'Traffic Shaping Enabled:[[:space:]]*true' && \
   echo "$CONFIG_RESULT" | grep -Eq 'Stats Detail Level:[[:space:]]*aggregate'; then
  echo "✅ Success: Default aggregate detail mode reported."
else
  echo "❌ Error: Traffic shaping config output missing enabled state or aggregate detail mode."
  echo "Debug Info: $CONFIG_RESULT"
  FAILURES=$((FAILURES + 1))
fi

if echo "$CONFIG_JSON_RESULT" | jq -e '.enabled == true and .detail_level == "aggregate" and (.estimators_update_period_ms == 100) and (.fst_io_policy_update_period_ms == 100) and (.fst_io_stats_reporting_period_ms == 100) and (.system_stats_time_window_seconds == 15)' > /dev/null; then
  echo "✅ Success: Traffic shaping config JSON output reported expected values."
else
  echo "❌ Error: Traffic shaping config JSON output missing expected values."
  echo "Debug Info: $CONFIG_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

if [[ "$JSON_RESULT" != *$'\n'* && "$USER_JSON_RESULT" != *$'\n'* && \
      "$USER_JSON_RESOLVED_RESULT" != *$'\n'* && "$CONFIG_JSON_RESULT" != *$'\n'* && \
      "$POLICY_JSON_RESULT" != *$'\n'* ]]; then
  echo "✅ Success: Traffic shaping JSON output is compact."
else
  echo "❌ Error: Traffic shaping JSON output contains unexpected line breaks."
  echo "Debug Info (ls): $JSON_RESULT"
  echo "Debug Info (users): $USER_JSON_RESULT"
  echo "Debug Info (users resolved): $USER_JSON_RESOLVED_RESULT"
  echo "Debug Info (config): $CONFIG_JSON_RESULT"
  echo "Debug Info (policy): $POLICY_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: Filesystem Detail Mode and Filesystem-Level Reporting
# ---------------------------------------------------------
DETAIL_APP="disk-detail-test-app-$$"
echo ""
echo "--- Testing Filesystem Detail Mode ---"

eos io shaping config set --detail fs
eos io shaping policy set --app ${DETAIL_APP} --limit-write 10M
sleep 8
xrdcp -f ${TEST_FILE_10MB} "${DEST_URL}/disk_detail_prime.dat?eos.app=${DETAIL_APP}" > /dev/null 2>&1
sleep 1

CONFIG_RESULT=$(eos io shaping config ls)

if echo "$CONFIG_RESULT" | grep -Eq 'Stats Detail Level:[[:space:]]*fs'; then
  echo "✅ Success: Filesystem detail mode enabled."
else
  echo "❌ Error: Filesystem detail mode was not reported as enabled."
  echo "Debug Info: $CONFIG_RESULT"
  FAILURES=$((FAILURES + 1))
fi

xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/disk_detail.dat?eos.app=${DETAIL_APP}" > /dev/null 2>&1 &
PID_DETAIL=$!

sleep 5
FS_JSON_RESULT=$(eos io shaping ls --window 5 --fs --json)
ALL_JSON_RESULT=$(eos io shaping ls --window 5 --all --json)
APP_JSON_RESULT=$(eos io shaping ls --window 5 --json)

kill -9 $PID_DETAIL 2>/dev/null; wait $PID_DETAIL 2>/dev/null || true
eos io shaping policy rm --app ${DETAIL_APP}
eos io shaping config set --detail aggregate
sleep 2

if echo "$FS_JSON_RESULT" | jq -e '.[] | select(.type == "fs" and (.node_id | type == "string" and length > 0) and (.fsid > 0) and (.write_rate_bps > 0))' > /dev/null; then
  FS_ID=$(echo "$FS_JSON_RESULT" | jq -r '.[] | select(.type == "fs" and (.node_id | type == "string" and length > 0) and (.fsid > 0) and (.write_rate_bps > 0)) | "\(.node_id) fsid=\(.fsid)"' | head -n1)
  echo "✅ Success: Filesystem-level traffic detected in filesystem detail mode ($FS_ID)."
else
  echo "⚠️ Warning: Filesystem-level traffic missing in filesystem detail mode."
  echo "Debug Info: $FS_JSON_RESULT"
fi

if echo "$ALL_JSON_RESULT" | jq -e --arg app "$DETAIL_APP" '.[] | select(.type == "all" and (.node_id | type == "string" and length > 0) and (.fsid > 0) and (.app == $app) and (.uid | type == "number") and (.gid | type == "number") and (.write_rate_bps > 0))' > /dev/null; then
  ALL_ID=$(echo "$ALL_JSON_RESULT" | jq -r --arg app "$DETAIL_APP" '.[] | select(.type == "all" and (.node_id | type == "string" and length > 0) and (.fsid > 0) and (.app == $app) and (.write_rate_bps > 0)) | "\(.node_id) fsid=\(.fsid) app=\(.app) uid=\(.uid) gid=\(.gid)"' | head -n1)
  echo "✅ Success: Full tag traffic detected in filesystem detail mode ($ALL_ID)."
else
  echo "⚠️ Warning: Full tag traffic missing in filesystem detail mode."
  echo "Debug Info: $ALL_JSON_RESULT"
fi

AGGREGATE_APP="aggregate-all-test-app-$$"
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/aggregate_all.dat?eos.app=${AGGREGATE_APP}" > /dev/null 2>&1 &
PID_AGGREGATE=$!

sleep 5
AGGREGATE_FS_JSON_RESULT=$(eos io shaping ls --window 5 --fs --json)
AGGREGATE_ALL_JSON_RESULT=$(eos io shaping ls --window 5 --all --json)

kill -9 $PID_AGGREGATE 2>/dev/null; wait $PID_AGGREGATE 2>/dev/null || true
eos io shaping config set --detail aggregate
sleep 2

if echo "$AGGREGATE_FS_JSON_RESULT" | jq -e 'length == 0' > /dev/null && \
   echo "$AGGREGATE_ALL_JSON_RESULT" | jq -e 'length > 0 and all(.[]; .type == "all" and .node_id == "<unknown>" and .fsid == 0)' > /dev/null && \
   echo "$AGGREGATE_ALL_JSON_RESULT" | jq -e --arg app "$AGGREGATE_APP" '.[] | select(.app == $app and (.uid | type == "number") and (.gid | type == "number") and (.write_rate_bps > 0))' > /dev/null; then
  echo "✅ Success: Aggregate detail mode hides --fs and exposes --all with sentinel node/fs values."
else
  echo "❌ Error: Aggregate detail mode did not return expected --fs/--all output."
  echo "Debug Info (--fs): $AGGREGATE_FS_JSON_RESULT"
  echo "Debug Info (--all): $AGGREGATE_ALL_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

if echo "$APP_JSON_RESULT" | jq -e --arg app "$DETAIL_APP" '.[] | select(.id == $app) | (.write_rate_bps > 0)' > /dev/null; then
  echo "✅ Success: App-level reporting still works in filesystem detail mode."
else
  echo "❌ Error: App-level reporting missing in filesystem detail mode."
  echo "Debug Info: $APP_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: App Throttling Enforcement
# ---------------------------------------------------------
THROTTLE_APP="throttle-test-app-$$"
echo ""
echo "--- Testing App Throttling ---"

echo "Applying 1 MB/s write limit..."
eos io shaping policy set --app ${THROTTLE_APP} --limit-write 1M
sleep 3

APP_WRITE_MS=$(measure_transfer_ms "${TEST_FILE_10MB}" "${DEST_URL}/test.dat?eos.app=${THROTTLE_APP}")
eos io shaping policy rm --app ${THROTTLE_APP}

if [[ $APP_WRITE_MS -ge $WRITE_10MB_LOWER_MS && $APP_WRITE_MS -le $WRITE_10MB_UPPER_MS ]]; then
  echo "✅ Success: App write throttled properly (${APP_WRITE_MS} ms)."
else
  echo "❌ Error: Expected app write transfer duration between ${WRITE_10MB_LOWER_MS}-${WRITE_10MB_UPPER_MS} ms, got ${APP_WRITE_MS} ms."
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: UID Throttling Enforcement
# ---------------------------------------------------------
TEST_UID=$((19000 + ($$ % 1000)))
echo ""
echo "--- Testing UID Throttling ---"

eos io shaping policy set --uid ${TEST_UID} --limit-write 1M
sleep 3

UID_WRITE_MS=$(measure_transfer_ms "${TEST_FILE_10MB}" "${DEST_URL}/uid_test.dat?eos.ruid=${TEST_UID}")
eos io shaping policy rm --uid ${TEST_UID}

if [[ $UID_WRITE_MS -ge $WRITE_10MB_LOWER_MS && $UID_WRITE_MS -le $WRITE_10MB_UPPER_MS ]]; then
  echo "✅ Success: UID write throttled properly (${UID_WRITE_MS} ms)."
else
  echo "❌ Error: Expected UID write transfer duration between ${WRITE_10MB_LOWER_MS}-${WRITE_10MB_UPPER_MS} ms, got ${UID_WRITE_MS} ms."
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: UID Read Throttling Enforcement
# ---------------------------------------------------------
TEST_READ_UID=$((18000 + ($$ % 1000)))
echo ""
echo "--- Testing UID Read Throttling ---"

xrdcp -f ${TEST_FILE_10MB} "${DEST_URL}/uid_read_source.dat?eos.ruid=${TEST_READ_UID}" > /dev/null 2>&1

eos io shaping policy set --uid ${TEST_READ_UID} --limit-read 1M
sleep 3

UID_READ_MS=$(measure_transfer_ms "${DEST_URL}/uid_read_source.dat?eos.ruid=${TEST_READ_UID}" /dev/null)
eos io shaping policy rm --uid ${TEST_READ_UID}

if [[ $UID_READ_MS -ge $READ_10MB_LOWER_MS && $UID_READ_MS -le $READ_10MB_UPPER_MS ]]; then
  echo "✅ Success: UID read throttled properly (${UID_READ_MS} ms)."
else
  echo "❌ Error: Expected UID read transfer duration between ${READ_10MB_LOWER_MS}-${READ_10MB_UPPER_MS} ms, got ${UID_READ_MS} ms."
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: GID Throttling Enforcement
# ---------------------------------------------------------
TEST_GID=$((17000 + ($$ % 1000)))
echo ""
echo "--- Testing GID Throttling ---"

eos io shaping policy set --gid ${TEST_GID} --limit-write 1M
sleep 3

GID_WRITE_MS=$(measure_transfer_ms "${TEST_FILE_10MB}" "${DEST_URL}/gid_test.dat?eos.rgid=${TEST_GID}")
eos io shaping policy rm --gid ${TEST_GID}

if [[ $GID_WRITE_MS -ge $WRITE_10MB_LOWER_MS && $GID_WRITE_MS -le $WRITE_10MB_UPPER_MS ]]; then
  echo "✅ Success: GID write throttled properly (${GID_WRITE_MS} ms)."
else
  echo "❌ Error: Expected GID write transfer duration between ${WRITE_10MB_LOWER_MS}-${WRITE_10MB_UPPER_MS} ms, got ${GID_WRITE_MS} ms."
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: GID Read Throttling Enforcement
# ---------------------------------------------------------
TEST_READ_GID=$((16000 + ($$ % 1000)))
echo ""
echo "--- Testing GID Read Throttling ---"

xrdcp -f ${TEST_FILE_10MB} "${DEST_URL}/gid_read_source.dat?eos.rgid=${TEST_READ_GID}" > /dev/null 2>&1

eos io shaping policy set --gid ${TEST_READ_GID} --limit-read 1M
sleep 3

GID_READ_MS=$(measure_transfer_ms "${DEST_URL}/gid_read_source.dat?eos.rgid=${TEST_READ_GID}" /dev/null)
eos io shaping policy rm --gid ${TEST_READ_GID}

if [[ $GID_READ_MS -ge $READ_10MB_LOWER_MS && $GID_READ_MS -le $READ_10MB_UPPER_MS ]]; then
  echo "✅ Success: GID read throttled properly (${GID_READ_MS} ms)."
else
  echo "❌ Error: Expected GID read transfer duration between ${READ_10MB_LOWER_MS}-${READ_10MB_UPPER_MS} ms, got ${GID_READ_MS} ms."
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: App Read Throttling Enforcement
# ---------------------------------------------------------
READ_APP="read-throttle-app-$$"
echo ""
echo "--- Testing App Read Throttling ---"

xrdcp -f ${TEST_FILE_10MB} "${DEST_URL}/read_test.dat" > /dev/null 2>&1

eos io shaping policy set --app ${READ_APP} --limit-read 1M
sleep 3

READ_APP_MS=$(measure_transfer_ms "${DEST_URL}/read_test.dat?eos.app=${READ_APP}" /dev/null)
eos io shaping policy rm --app ${READ_APP}

if [[ $READ_APP_MS -ge $READ_10MB_LOWER_MS && $READ_APP_MS -le $READ_10MB_UPPER_MS ]]; then
  echo "✅ Success: App read throttled properly (${READ_APP_MS} ms)."
else
  echo "❌ Error: Expected app read transfer duration between ${READ_10MB_LOWER_MS}-${READ_10MB_UPPER_MS} ms, got ${READ_APP_MS} ms."
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: Write Limit Does Not Throttle Reads
# ---------------------------------------------------------
WRITE_ONLY_APP="write-only-limit-app-$$"
echo ""
echo "--- Testing Write Limit Does Not Throttle Reads ---"

xrdcp -f ${TEST_FILE_10MB} "${DEST_URL}/write_only_read_source.dat?eos.app=${WRITE_ONLY_APP}" > /dev/null 2>&1

echo "Priming write feedback loop..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/write_only_prime.dat?eos.app=${WRITE_ONLY_APP}" > /dev/null 2>&1

echo "Creating active write delay for ${WRITE_ONLY_APP}..."
eos io shaping policy set --app ${WRITE_ONLY_APP} --limit-write 1M
sleep 3
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/write_only_active.dat?eos.app=${WRITE_ONLY_APP}" > /dev/null 2>&1 &
PID_WO_W=$!

echo "Waiting 22 seconds for write throttle stabilization..."
sleep 22

START_MS=$(date +%s%3N)
xrdcp -f "${DEST_URL}/write_only_read_source.dat?eos.app=${WRITE_ONLY_APP}" /dev/null > /dev/null 2>&1
READ_RC=$?
END_MS=$(date +%s%3N)

kill -9 $PID_WO_W 2>/dev/null; wait $PID_WO_W 2>/dev/null || true
eos io shaping policy rm --app ${WRITE_ONLY_APP}

READ_DURATION_MS=$((END_MS - START_MS))

if [[ $READ_RC -eq 0 && $READ_DURATION_MS -lt 8000 ]]; then
  echo "✅ Success: Write-only limit did not throttle read transfer (${READ_DURATION_MS} ms)."
else
  echo "❌ Error: Read transfer was unexpectedly slow or failed under write-only limit (rc=${READ_RC}, duration=${READ_DURATION_MS} ms)."
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: Policy Enable / Disable Toggle
# ---------------------------------------------------------
TOGGLE_APP="toggle-test-app-$$"
echo ""
echo "--- Testing Policy Toggle ---"

eos io shaping policy set --app ${TOGGLE_APP} --limit-write 1M
eos io shaping policy set --app ${TOGGLE_APP} --disable
sleep 3

START_MS=$(date +%s%3N)
xrdcp -f ${TEST_FILE_10MB} "${DEST_URL}/toggle_disabled.dat?eos.app=${TOGGLE_APP}" > /dev/null
END_MS=$(date +%s%3N)
echo "Transfer with disabled policy took $((END_MS - START_MS)) ms."

eos io shaping policy set --app ${TOGGLE_APP} --enable
sleep 3

TOGGLE_ENABLED_MS=$(measure_transfer_ms "${TEST_FILE_10MB}" "${DEST_URL}/toggle_test.dat?eos.app=${TOGGLE_APP}")
eos io shaping policy rm --app ${TOGGLE_APP}

if [[ $TOGGLE_ENABLED_MS -ge $WRITE_10MB_LOWER_MS && $TOGGLE_ENABLED_MS -le $WRITE_10MB_UPPER_MS ]]; then
  echo "✅ Success: Policy re-enabled correctly."
else
  echo "❌ Error: Policy toggle failed. Enabled transfer took ${TOGGLE_ENABLED_MS} ms."
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: Dynamic Limit Change (PID Convergence)
# ---------------------------------------------------------
DYN_APP="dynamic-limit-app-$$"
echo ""
echo "--- Testing Dynamic Limit Change ---"

echo "Applying 1 MB/s limit..."
eos io shaping policy set --app ${DYN_APP} --limit-write 1M
sleep 2

FIRST_LIMIT_MS=$(measure_transfer_ms "${TEST_FILE_10MB}" "${DEST_URL}/dyn_1m.dat?eos.app=${DYN_APP}")

echo "Changing limit dynamically to 2 MB/s..."
eos io shaping policy set --app ${DYN_APP} --limit-write 2M
sleep 4
SECOND_LIMIT_MS=$(measure_transfer_ms "${TEST_FILE_10MB}" "${DEST_URL}/dyn_2m.dat?eos.app=${DYN_APP}")
eos io shaping policy rm --app ${DYN_APP}

if [[ $FIRST_LIMIT_MS -ge $WRITE_10MB_LOWER_MS && $FIRST_LIMIT_MS -le $WRITE_10MB_UPPER_MS && $SECOND_LIMIT_MS -lt $FIRST_LIMIT_MS && $SECOND_LIMIT_MS -ge 3500 && $SECOND_LIMIT_MS -le 14000 ]]; then
  echo "✅ Success: Dynamic limit change reduced transfer time (${FIRST_LIMIT_MS} ms -> ${SECOND_LIMIT_MS} ms)."
else
  echo "❌ Error: Dynamic limit timing failed. 1M=${FIRST_LIMIT_MS} ms 2M=${SECOND_LIMIT_MS} ms."
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: Multiple SMA/EMA Windows Consistency
# ---------------------------------------------------------
echo ""
echo "--- Testing Multiple Windows Consistency ---"

WINDOW_APP="window-test-app-$$"
( while true; do xrdcp -f ${TEST_FILE_10MB} "${DEST_URL}/window_test.dat?eos.app=${WINDOW_APP}" -s > /dev/null 2>&1; done ) &
PID=$!

MAX_RATE_1S=0
MAX_RATE_5S=0
RESULT_1S="[]"
RESULT_5S="[]"

for _ in {1..10}; do
  sleep 1
  RESULT_1S=$(eos io shaping ls --window 1 --json)
  RESULT_5S=$(eos io shaping ls --window 5 --json)

  RATE_1S=$(echo "$RESULT_1S" | jq -r --arg app "$WINDOW_APP" 'map(select(.id == $app) | .write_rate_bps) | max // 0')
  RATE_5S=$(echo "$RESULT_5S" | jq -r --arg app "$WINDOW_APP" 'map(select(.id == $app) | .write_rate_bps) | max // 0')

  if (( $(echo "$RATE_1S > $MAX_RATE_1S" | bc -l) )); then
    MAX_RATE_1S=$RATE_1S
  fi

  if (( $(echo "$RATE_5S > $MAX_RATE_5S" | bc -l) )); then
    MAX_RATE_5S=$RATE_5S
  fi

  if (( $(echo "$MAX_RATE_1S > 0" | bc -l) )) && (( $(echo "$MAX_RATE_5S > 0" | bc -l) )); then
    break
  fi
done

kill -9 $PID 2>/dev/null; wait $PID 2>/dev/null || true

if (( $(echo "$MAX_RATE_1S > 0" | bc -l) )) && (( $(echo "$MAX_RATE_5S > 0" | bc -l) )); then
  echo "✅ Success: Both windows report non-zero rates (1s max: $MAX_RATE_1S bps, 5s max: $MAX_RATE_5S bps)."
else
  echo "❌ Error: Zero rate detected. 1s max: $MAX_RATE_1S bps, 5s max: $MAX_RATE_5S bps."
  echo "Debug Info: 1s: $RESULT_1S, 5s: $RESULT_5S"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: Simultaneous Read and Write Limits
# ---------------------------------------------------------
RW_APP="rw-limit-app-$$"
echo ""
echo "--- Testing Simultaneous R/W Limits ---"

xrdcp -f ${TEST_FILE_10MB} "${DEST_URL}/rw_test.dat?eos.app=${RW_APP}" > /dev/null 2>&1

eos io shaping policy set --app ${RW_APP} --limit-read 1M --limit-write 1M
sleep 3

RW_START_MS=$(date +%s%3N)
xrdcp -f ${TEST_FILE_10MB} "${DEST_URL}/rw_write.dat?eos.app=${RW_APP}" > /dev/null 2>&1 &
PID_W=$!
xrdcp -f "${DEST_URL}/rw_test.dat?eos.app=${RW_APP}" /dev/null > /dev/null 2>&1 &
PID_R=$!

wait $PID_W
RW_W_RC=$?
wait $PID_R
RW_R_RC=$?
RW_END_MS=$(date +%s%3N)
RW_ELAPSED_MS=$((RW_END_MS - RW_START_MS))
eos io shaping policy rm --app ${RW_APP}

if [[ $RW_W_RC -eq 0 && $RW_R_RC -eq 0 && $RW_ELAPSED_MS -ge $READ_10MB_LOWER_MS && $RW_ELAPSED_MS -le $READ_10MB_UPPER_MS ]]; then
  echo "✅ Success: Simultaneous read/write limits enforced (${RW_ELAPSED_MS} ms)."
else
  echo "❌ Error: Simultaneous R/W limit failure. elapsed=${RW_ELAPSED_MS} ms write_rc=${RW_W_RC} read_rc=${RW_R_RC}."
  FAILURES=$((FAILURES + 1))
fi

echo ""
if [[ $FAILURES -eq 0 ]]; then
  echo "🎉 All validations passed perfectly!"
  exit 0
else
  echo "❌ Completed with $FAILURES errors. Failing the pipeline."
  exit 1
fi
