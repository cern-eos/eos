#!/bin/bash
# ----------------------------------------------------------------------
# File: eos-traffic-shaping-test
# Author: Luis Antonio Obis Aparicio - CERN
# ----------------------------------------------------------------------

if [[ $# -ne 2 ]]; then
  echo "Error: Missing arguments."
  echo "Usage:    $0 <eos_mgm_hostname> <eos_instance_name>"
  echo "Examples:"
  echo "  $0 example.cern.ch example"
  echo "  $0 localhost dev"
  exit 1
fi

EOS_MGM_HOSTNAME=$1
EOS_INSTANCE_NAME=$2
FAILURES=0

echo "Configuring MGM Host: $EOS_MGM_HOSTNAME"
echo "Instance Name: $EOS_INSTANCE_NAME"

if ! command -v jq &> /dev/null; then
  echo "Error: 'jq' is required but not installed."
  exit 1
fi

export XrdSecPROTOCOL=sss

# Enable traffic shaping
eos io shaping enable

eos io shaping config set --estimators-period 100 --report-period 100 --policy-period 100 --system-window 15 --detail aggregate
sleep 8

echo "Creating dummy files (10MB and 200MB)..."
TEST_FILE_10MB=/tmp/10mb.dat
dd if=/dev/urandom of=${TEST_FILE_10MB} bs=1M count=10 iflag=fullblock &> /dev/null

TEST_FILE_200MB=/tmp/200mb_throttle.dat
dd if=/dev/urandom of=${TEST_FILE_200MB} bs=1M count=200 iflag=fullblock &> /dev/null

DEST_URL="root://${EOS_MGM_HOSTNAME}//eos/${EOS_INSTANCE_NAME}/traffic_shaping"

eos mkdir -p /eos/${EOS_INSTANCE_NAME}/traffic_shaping/
eos chmod 2777 /eos/${EOS_INSTANCE_NAME}/
eos chmod 2777 /eos/${EOS_INSTANCE_NAME}/traffic_shaping/

# ±20% lower, ±35% upper for 1 MB/s target
LOWER_BOUND=800000
UPPER_BOUND=1350000

# ---------------------------------------------------------
# Test: Baseline System and Reporting Engine
# ---------------------------------------------------------
echo ""
echo "--- Testing Baseline System and Reporting Engine ---"
xrdcp ${TEST_FILE_10MB} "${DEST_URL}/10mb.dat?eos.app=traffic-shaping-test-app" -f > /dev/null
sleep 1

JSON_RESULT=$(eos io shaping ls --window 15 --sys --json)

if echo "$JSON_RESULT" | jq -e '.[] | select(.id == "traffic-shaping-test-app") | (.write_rate_bps > 0)' > /dev/null; then
  echo "✅ Success: Baseline traffic detected."
else
  echo "❌ Error: Baseline traffic missing."
  echo "Debug Info: $JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

CONFIG_RESULT=$(eos io shaping config ls)

if echo "$CONFIG_RESULT" | grep -Eq 'Traffic Shaping Enabled:[[:space:]]*true' && \
   echo "$CONFIG_RESULT" | grep -Eq 'Stats Detail Level:[[:space:]]*aggregate'; then
  echo "✅ Success: Default aggregate detail mode reported."
else
  echo "❌ Error: Traffic shaping config output missing enabled state or aggregate detail mode."
  echo "Debug Info: $CONFIG_RESULT"
  FAILURES=$((FAILURES + 1))
fi

if echo "$CONFIG_JSON_RESULT" | jq -e '.enabled == true and .detail_level == "aggregate" and (.estimators_update_period_ms == 100) and (.fst_io_policy_update_period_ms == 100) and (.fst_io_stats_reporting_period_ms == 100) and (.system_stats_time_window_seconds == 15)' > /dev/null; then
  echo "✅ Success: Traffic shaping config JSON output reported expected values."
else
  echo "❌ Error: Traffic shaping config JSON output missing expected values."
  echo "Debug Info: $CONFIG_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

if [[ "$JSON_RESULT" != *$'\n'* && "$USER_JSON_RESULT" != *$'\n'* && \
      "$USER_JSON_RESOLVED_RESULT" != *$'\n'* && "$CONFIG_JSON_RESULT" != *$'\n'* && \
      "$POLICY_JSON_RESULT" != *$'\n'* ]]; then
  echo "✅ Success: Traffic shaping JSON output is compact."
else
  echo "❌ Error: Traffic shaping JSON output contains unexpected line breaks."
  echo "Debug Info (ls): $JSON_RESULT"
  echo "Debug Info (users): $USER_JSON_RESULT"
  echo "Debug Info (users resolved): $USER_JSON_RESOLVED_RESULT"
  echo "Debug Info (config): $CONFIG_JSON_RESULT"
  echo "Debug Info (policy): $POLICY_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: Filesystem Detail Mode and Disk-Level Reporting
# ---------------------------------------------------------
DETAIL_APP="disk-detail-test-app"
echo ""
echo "--- Testing Filesystem Detail Mode ---"

eos io shaping config set --detail fs
sleep 8

CONFIG_RESULT=$(eos io shaping config ls)

if echo "$CONFIG_RESULT" | grep -Eq 'Stats Detail Level:[[:space:]]*fs'; then
  echo "✅ Success: Filesystem detail mode enabled."
else
  echo "❌ Error: Filesystem detail mode was not reported as enabled."
  echo "Debug Info: $CONFIG_RESULT"
  FAILURES=$((FAILURES + 1))
fi

xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/disk_detail.dat?eos.app=${DETAIL_APP}" > /dev/null 2>&1 &
PID_DETAIL=$!

sleep 5
DISK_JSON_RESULT=$(eos io shaping ls --window 5 --disks --json)
APP_JSON_RESULT=$(eos io shaping ls --window 5 --json)

kill -9 $PID_DETAIL 2>/dev/null; wait $PID_DETAIL 2>/dev/null || true
eos io shaping config set --detail aggregate
sleep 2
AGGREGATE_DISK_JSON_RESULT=$(eos io shaping ls --window 5 --disks --json)

if echo "$DISK_JSON_RESULT" | jq -e '.[] | select(.type == "disk" and (.node_id | type == "string" and length > 0) and (.fsid > 0) and (.write_rate_bps > 0))' > /dev/null; then
  DISK_ID=$(echo "$DISK_JSON_RESULT" | jq -r '.[] | select(.type == "disk" and (.node_id | type == "string" and length > 0) and (.fsid > 0) and (.write_rate_bps > 0)) | "\(.node_id) fsid=\(.fsid)"' | head -n1)
  echo "✅ Success: Disk-level traffic detected in filesystem detail mode ($DISK_ID)."
else
  echo "❌ Error: Disk-level traffic missing in filesystem detail mode."
  echo "Debug Info: $DISK_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

if echo "$AGGREGATE_DISK_JSON_RESULT" | jq -e 'length == 0' > /dev/null; then
  echo "✅ Success: Disk-level output is hidden in aggregate detail mode."
else
  echo "❌ Error: Disk-level output still visible in aggregate detail mode."
  echo "Debug Info: $AGGREGATE_DISK_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

if echo "$APP_JSON_RESULT" | jq -e --arg app "$DETAIL_APP" '.[] | select(.id == $app) | (.write_rate_bps > 0)' > /dev/null; then
  echo "✅ Success: App-level reporting still works in filesystem detail mode."
else
  echo "❌ Error: App-level reporting missing in filesystem detail mode."
  echo "Debug Info: $APP_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: App Throttling Enforcement
# ---------------------------------------------------------
THROTTLE_APP="throttle-test-app"
echo ""
echo "--- Testing App Throttling ---"

echo "Priming feedback loop..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/prime.dat?eos.app=${THROTTLE_APP}" > /dev/null 2>&1

echo "Applying 1 MB/s write limit..."
eos io shaping policy set --app ${THROTTLE_APP} --limit-write 1M
sleep 3

echo "Starting throttled background transfer..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/test.dat?eos.app=${THROTTLE_APP}" > /dev/null 2>&1 &
PID=$!

echo "Waiting 22 seconds for strict EMA stabilization..."
sleep 22
JSON_RESULT=$(eos io shaping ls --window 5 --json)
kill -9 $PID 2>/dev/null; wait $PID 2>/dev/null || true
eos io shaping policy rm --app ${THROTTLE_APP}

if echo "$JSON_RESULT" | jq -e --argjson l "$LOWER_BOUND" --argjson u "$UPPER_BOUND" '.[] | select(.id == "throttle-test-app") | (.write_rate_bps > $l) and (.write_rate_bps < $u)' > /dev/null; then
  RATE=$(echo "$JSON_RESULT" | jq -r '.[] | select(.id == "throttle-test-app") | .write_rate_bps')
  echo "✅ Success: App throttled properly ($RATE bps)."
else
  RATE=$(echo "$JSON_RESULT" | jq -r '.[] | select(.id == "throttle-test-app") | .write_rate_bps // 0')
  echo "❌ Error: Expected ~1MB/s, got $RATE bps."
  echo "Debug Info: $JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: UID Throttling Enforcement
# ---------------------------------------------------------
TEST_UID="19999"
echo ""
echo "--- Testing UID Throttling ---"

echo "Priming feedback loop..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/uid_prime.dat?eos.ruid=${TEST_UID}" > /dev/null 2>&1

eos io shaping policy set --uid ${TEST_UID} --limit-write 1M
sleep 3

xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/uid_test.dat?eos.ruid=${TEST_UID}" > /dev/null 2>&1 &
PID=$!

echo "Waiting 22 seconds for strict EMA stabilization..."
sleep 22
JSON_RESULT=$(eos io shaping ls --window 5 --users --json)
kill -9 $PID 2>/dev/null; wait $PID 2>/dev/null || true
eos io shaping policy rm --uid ${TEST_UID}

if echo "$JSON_RESULT" | jq -e --argjson l "$LOWER_BOUND" --argjson u "$UPPER_BOUND" '.[] | select(.id == "19999") | (.write_rate_bps > $l) and (.write_rate_bps < $u)' > /dev/null; then
  echo "✅ Success: UID throttled properly."
else
  RATE=$(echo "$JSON_RESULT" | jq -r '.[] | select(.id == "19999") | .write_rate_bps // 0')
  echo "❌ Error: Expected ~1MB/s, got $RATE bps."
  echo "Debug Info: $JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: GID Throttling Enforcement
# ---------------------------------------------------------
TEST_GID="18888"
echo ""
echo "--- Testing GID Throttling ---"

echo "Priming feedback loop..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/gid_prime.dat?eos.rgid=${TEST_GID}" > /dev/null 2>&1

eos io shaping policy set --gid ${TEST_GID} --limit-write 1M
sleep 3

xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/gid_test.dat?eos.rgid=${TEST_GID}" > /dev/null 2>&1 &
PID=$!

echo "Waiting 22 seconds for strict EMA stabilization..."
sleep 22
JSON_RESULT=$(eos io shaping ls --window 5 --groups --json)
kill -9 $PID 2>/dev/null; wait $PID 2>/dev/null || true
eos io shaping policy rm --gid ${TEST_GID}

if echo "$JSON_RESULT" | jq -e --argjson l "$LOWER_BOUND" --argjson u "$UPPER_BOUND" '.[] | select(.id == "18888") | (.write_rate_bps > $l) and (.write_rate_bps < $u)' > /dev/null; then
  echo "✅ Success: GID throttled properly."
else
  RATE=$(echo "$JSON_RESULT" | jq -r '.[] | select(.id == "18888") | .write_rate_bps // 0')
  echo "❌ Error: Expected ~1MB/s, got $RATE bps."
  echo "Debug Info: $JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: App Read Throttling Enforcement
# ---------------------------------------------------------
READ_APP="read-throttle-app"
echo ""
echo "--- Testing App Read Throttling ---"

xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/read_test.dat" > /dev/null 2>&1
echo "Priming read feedback loop..."
xrdcp -f "${DEST_URL}/read_test.dat?eos.app=${READ_APP}" /dev/null > /dev/null 2>&1

eos io shaping policy set --app ${READ_APP} --limit-read 1M
sleep 3

xrdcp -f "${DEST_URL}/read_test.dat?eos.app=${READ_APP}" /dev/null > /dev/null 2>&1 &
PID=$!

echo "Waiting 22 seconds for strict EMA stabilization..."
sleep 22
JSON_RESULT=$(eos io shaping ls --window 5 --json)
kill -9 $PID 2>/dev/null; wait $PID 2>/dev/null || true
eos io shaping policy rm --app ${READ_APP}

if echo "$JSON_RESULT" | jq -e --argjson l "$LOWER_BOUND" --argjson u "$UPPER_BOUND" '.[] | select(.id == "read-throttle-app") | (.read_rate_bps > $l) and (.read_rate_bps < $u)' > /dev/null; then
  echo "✅ Success: App read throttled properly."
else
  RATE=$(echo "$JSON_RESULT" | jq -r '.[] | select(.id == "read-throttle-app") | .read_rate_bps // 0')
  echo "❌ Error: Expected ~1MB/s, got $RATE bps."
  echo "Debug Info: $JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: Policy Enable / Disable Toggle
# ---------------------------------------------------------
TOGGLE_APP="toggle-test-app"
echo ""
echo "--- Testing Policy Toggle ---"

eos io shaping policy set --app ${TOGGLE_APP} --limit-write 1M
eos io shaping policy set --app ${TOGGLE_APP} --disable
sleep 3

START_MS=$(date +%s%3N)
xrdcp -f ${TEST_FILE_10MB} "${DEST_URL}/toggle_disabled.dat?eos.app=${TOGGLE_APP}" > /dev/null
END_MS=$(date +%s%3N)
echo "Transfer with disabled policy took $((END_MS - START_MS)) ms."

eos io shaping policy set --app ${TOGGLE_APP} --enable
echo "Priming feedback loop..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/toggle_prime.dat?eos.app=${TOGGLE_APP}" > /dev/null 2>&1
sleep 3

xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/toggle_test.dat?eos.app=${TOGGLE_APP}" > /dev/null 2>&1 &
PID=$!

echo "Waiting 22 seconds for strict EMA stabilization..."
sleep 22
JSON_RESULT=$(eos io shaping ls --window 5 --json)
kill -9 $PID 2>/dev/null; wait $PID 2>/dev/null || true
eos io shaping policy rm --app ${TOGGLE_APP}

if echo "$JSON_RESULT" | jq -e --argjson l "$LOWER_BOUND" --argjson u "$UPPER_BOUND" '.[] | select(.id == "toggle-test-app") | (.write_rate_bps > $l) and (.write_rate_bps < $u)' > /dev/null; then
  echo "✅ Success: Policy re-enabled correctly."
else
  RATE=$(echo "$JSON_RESULT" | jq -r '.[] | select(.id == "toggle-test-app") | .write_rate_bps // 0')
  echo "❌ Error: Policy toggle failed. Got $RATE bps."
  echo "Debug Info: $JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: Dynamic Limit Change (PID Convergence)
# ---------------------------------------------------------
DYN_APP="dynamic-limit-app"
echo ""
echo "--- Testing Dynamic Limit Change ---"

echo "Applying 1 MB/s limit..."
eos io shaping policy set --app ${DYN_APP} --limit-write 1M

echo "Priming feedback loop..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/dyn_prime.dat?eos.app=${DYN_APP}" > /dev/null 2>&1
sleep 2

echo "Starting background transfer..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/dyn_test.dat?eos.app=${DYN_APP}" > /dev/null 2>&1 &
PID_DYN=$!

echo "Waiting 20 seconds for PID to stabilize at 1 MB/s..."
sleep 20

echo "Changing limit dynamically to 2 MB/s..."
eos io shaping policy set --app ${DYN_APP} --limit-write 2M

echo "Waiting 22 seconds for PID to release and converge to new 2 MB/s limit..."
sleep 22

JSON_RESULT=$(eos io shaping ls --window 5 --json)
kill -9 $PID_DYN 2>/dev/null; wait $PID_DYN 2>/dev/null || true
eos io shaping policy rm --app ${DYN_APP}

# Adjusted bounds to match the new strict ±20% tolerance for 2 MB/s (1.6M to 2.4M)
if echo "$JSON_RESULT" | jq -e --argjson l 1600000 --argjson u 2400000 '.[] | select(.id == "dynamic-limit-app") | (.write_rate_bps > $l) and (.write_rate_bps < $u)' > /dev/null; then
  RATE=$(echo "$JSON_RESULT" | jq -r '.[] | select(.id == "dynamic-limit-app") | .write_rate_bps')
  echo "✅ Success: PID converged to new limit ($RATE bps)."
else
  RATE=$(echo "$JSON_RESULT" | jq -r '.[] | select(.id == "dynamic-limit-app") | .write_rate_bps // 0')
  echo "❌ Error: PID convergence failed. Got $RATE bps."
  echo "Debug Info: $JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: Multiple SMA/EMA Windows Consistency
# ---------------------------------------------------------
echo ""
echo "--- Testing Multiple Windows Consistency ---"

WINDOW_APP="window-test-app"
( while true; do xrdcp -f ${TEST_FILE_10MB} "${DEST_URL}/window_test.dat?eos.app=${WINDOW_APP}" -s > /dev/null 2>&1; done ) &
PID=$!

sleep 5
RESULT_1S=$(eos io shaping ls --window 1 --json)
RESULT_5S=$(eos io shaping ls --window 5 --json)

kill -9 $PID 2>/dev/null; wait $PID 2>/dev/null || true

RATE_1S=$(echo "$RESULT_1S" | jq -r ".[] | select(.id == \"${WINDOW_APP}\") | .write_rate_bps // 0")
RATE_5S=$(echo "$RESULT_5S" | jq -r ".[] | select(.id == \"${WINDOW_APP}\") | .write_rate_bps // 0")

if (( $(echo "$RATE_1S > 0" | bc -l) )) && (( $(echo "$RATE_5S > 0" | bc -l) )); then
  echo "✅ Success: Both windows report non-zero rates (1s: $RATE_1S bps, 5s: $RATE_5S bps)."
else
  echo "❌ Error: Zero rate detected. 1s: $RATE_1S bps, 5s: $RATE_5S bps."
  echo "Debug Info: 1s: $RESULT_1S, 5s: $RESULT_5S"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: Simultaneous Read and Write Limits
# ---------------------------------------------------------
RW_APP="rw-limit-app"
echo ""
echo "--- Testing Simultaneous R/W Limits ---"

xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/rw_test.dat?eos.app=${RW_APP}" > /dev/null 2>&1

echo "Priming feedback loops..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/rw_prime.dat?eos.app=${RW_APP}" > /dev/null 2>&1
xrdcp -f "${DEST_URL}/rw_test.dat?eos.app=${RW_APP}" /dev/null > /dev/null 2>&1

eos io shaping policy set --app ${RW_APP} --limit-read 1M --limit-write 1M
sleep 3

xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/rw_write.dat?eos.app=${RW_APP}" > /dev/null 2>&1 &
PID_W=$!
xrdcp -f "${DEST_URL}/rw_test.dat?eos.app=${RW_APP}" /dev/null > /dev/null 2>&1 &
PID_R=$!

echo "Waiting 22 seconds for strict EMA stabilization..."
sleep 22
JSON_RESULT=$(eos io shaping ls --window 5 --json)

kill -9 $PID_W $PID_R 2>/dev/null; wait $PID_W $PID_R 2>/dev/null || true
eos io shaping policy rm --app ${RW_APP}

RW_W_RATE=$(echo "$JSON_RESULT" | jq -r ".[] | select(.id == \"${RW_APP}\") | .write_rate_bps // 0")
RW_R_RATE=$(echo "$JSON_RESULT" | jq -r ".[] | select(.id == \"${RW_APP}\") | .read_rate_bps // 0")

if (( $(echo "$RW_W_RATE > $LOWER_BOUND" | bc -l) )) && (( $(echo "$RW_R_RATE > $LOWER_BOUND" | bc -l) )); then
  echo "✅ Success: Both independently throttled (R: $RW_R_RATE, W: $RW_W_RATE)."
else
  echo "❌ Error: R/W failure. R: $RW_R_RATE, W: $RW_W_RATE."
  echo "Debug Info: $JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

echo ""
if [[ $FAILURES -eq 0 ]]; then
  echo "🎉 All validations passed perfectly!"
  exit 0
else
  echo "❌ Completed with $FAILURES errors. Failing the pipeline."
  exit 1
fi
