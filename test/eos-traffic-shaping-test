#!/bin/bash
# ----------------------------------------------------------------------
# File: eos-traffic-shaping-test
# Author: Luis Antonio Obis Aparicio - CERN
# ----------------------------------------------------------------------

if [[ $# -ne 2 ]]; then
  echo "Error: Missing arguments."
  echo "Usage:    $0 <eos_mgm_hostname> <eos_instance_name>"
  echo "Examples:"
  echo "  $0 example.cern.ch example"
  echo "  $0 localhost dev"
  exit 1
fi

EOS_MGM_HOSTNAME=$1
EOS_INSTANCE_NAME=$2
FAILURES=0

echo "Configuring MGM Host: $EOS_MGM_HOSTNAME"
echo "Instance Name: $EOS_INSTANCE_NAME"

if ! command -v jq &> /dev/null; then
  echo "Error: 'jq' is required but not installed."
  exit 1
fi

export XrdSecPROTOCOL=sss

# Enable traffic shaping
eos io shaping enable

eos io shaping config set --estimators-period 100 --report-period 100 --policy-period 100 --system-window 15
eos io shaping config set --detail aggregate
sleep 8

echo "Creating dummy files (10MB and 200MB)..."
TEST_FILE_10MB=/tmp/10mb.dat
dd if=/dev/urandom of=${TEST_FILE_10MB} bs=1M count=10 iflag=fullblock &> /dev/null

TEST_FILE_200MB=/tmp/200mb_throttle.dat
dd if=/dev/urandom of=${TEST_FILE_200MB} bs=1M count=200 iflag=fullblock &> /dev/null

DEST_URL="root://${EOS_MGM_HOSTNAME}//eos/${EOS_INSTANCE_NAME}/traffic_shaping"

eos mkdir -p /eos/${EOS_INSTANCE_NAME}/traffic_shaping/
eos chmod 2777 /eos/${EOS_INSTANCE_NAME}/
eos chmod 2777 /eos/${EOS_INSTANCE_NAME}/traffic_shaping/

# ±20% lower, ±35% upper for 1 MB/s target
LOWER_BOUND=800000
UPPER_BOUND=1350000

wait_for_rate_in_range() {
  local entity_id=$1
  local rate_field=$2
  local lower_bound=$3
  local upper_bound=$4
  shift 4

  JSON_RESULT="[]"
  RATE=0

  for _ in {1..16}; do
    sleep 2
    JSON_RESULT=$(eos io shaping ls --window 5 "$@" --json)
    RATE=$(echo "$JSON_RESULT" | jq -r --arg id "$entity_id" --arg field "$rate_field" 'map(select(.id == $id) | .[$field]) | max // 0')

    if (( $(echo "$RATE > $lower_bound" | bc -l) )) && (( $(echo "$RATE < $upper_bound" | bc -l) )); then
      return 0
    fi
  done

  return 1
}

# ---------------------------------------------------------
# Test: Baseline System and Reporting Engine
# ---------------------------------------------------------
echo ""
echo "--- Testing Baseline System and Reporting Engine ---"
xrdcp ${TEST_FILE_10MB} "${DEST_URL}/10mb.dat?eos.app=traffic-shaping-test-app" -f > /dev/null
sleep 1

JSON_RESULT=$(eos io shaping ls --window 15 --sys --json)
USER_JSON_RESULT=$(eos io shaping ls --window 15 --users --json)
USER_JSON_RESOLVED_RESULT=$(eos io shaping ls --window 15 --users --json --resolve-ids)

if echo "$JSON_RESULT" | jq -e '.[] | select(.id == "traffic-shaping-test-app") | (.write_rate_bps > 0)' > /dev/null; then
  echo "✅ Success: Baseline traffic detected."
else
  echo "❌ Error: Baseline traffic missing."
  echo "Debug Info: $JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

if echo "$USER_JSON_RESULT" | jq -e '.[] | select(.type == "uid" and (.write_rate_bps > 0)) | has("name") | not' > /dev/null && \
   echo "$USER_JSON_RESOLVED_RESULT" | jq -e '.[] | select(.type == "uid" and (.write_rate_bps > 0) and (.name | type == "string" and length > 0))' > /dev/null; then
  echo "✅ Success: UID/GID name resolution is disabled by default in JSON and enabled on request."
else
  echo "❌ Error: UID/GID name resolution JSON defaults are not as expected."
  echo "Debug Info (--users --json): $USER_JSON_RESULT"
  echo "Debug Info (--users --json --resolve-ids): $USER_JSON_RESOLVED_RESULT"
  FAILURES=$((FAILURES + 1))
fi

CONFIG_RESULT=$(eos io shaping config ls)
CONFIG_JSON_RESULT=$(eos io shaping config ls --json)
POLICY_JSON_RESULT=$(eos io shaping policy ls --json)

if echo "$CONFIG_RESULT" | grep -Eq 'Traffic Shaping Enabled:[[:space:]]*true' && \
   echo "$CONFIG_RESULT" | grep -Eq 'Stats Detail Level:[[:space:]]*aggregate'; then
  echo "✅ Success: Default aggregate detail mode reported."
else
  echo "❌ Error: Traffic shaping config output missing enabled state or aggregate detail mode."
  echo "Debug Info: $CONFIG_RESULT"
  FAILURES=$((FAILURES + 1))
fi

if echo "$CONFIG_JSON_RESULT" | jq -e '.enabled == true and .detail_level == "aggregate" and (.estimators_update_period_ms == 100) and (.fst_io_policy_update_period_ms == 100) and (.fst_io_stats_reporting_period_ms == 100) and (.system_stats_time_window_seconds == 15)' > /dev/null; then
  echo "✅ Success: Traffic shaping config JSON output reported expected values."
else
  echo "❌ Error: Traffic shaping config JSON output missing expected values."
  echo "Debug Info: $CONFIG_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

if [[ "$JSON_RESULT" != *$'\n'* && "$USER_JSON_RESULT" != *$'\n'* && \
      "$USER_JSON_RESOLVED_RESULT" != *$'\n'* && "$CONFIG_JSON_RESULT" != *$'\n'* && \
      "$POLICY_JSON_RESULT" != *$'\n'* ]]; then
  echo "✅ Success: Traffic shaping JSON output is compact."
else
  echo "❌ Error: Traffic shaping JSON output contains unexpected line breaks."
  echo "Debug Info (ls): $JSON_RESULT"
  echo "Debug Info (users): $USER_JSON_RESULT"
  echo "Debug Info (users resolved): $USER_JSON_RESOLVED_RESULT"
  echo "Debug Info (config): $CONFIG_JSON_RESULT"
  echo "Debug Info (policy): $POLICY_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: Filesystem Detail Mode and Filesystem-Level Reporting
# ---------------------------------------------------------
DETAIL_APP="disk-detail-test-app"
echo ""
echo "--- Testing Filesystem Detail Mode ---"

eos io shaping config set --detail fs
sleep 8

CONFIG_RESULT=$(eos io shaping config ls)

if echo "$CONFIG_RESULT" | grep -Eq 'Stats Detail Level:[[:space:]]*fs'; then
  echo "✅ Success: Filesystem detail mode enabled."
else
  echo "❌ Error: Filesystem detail mode was not reported as enabled."
  echo "Debug Info: $CONFIG_RESULT"
  FAILURES=$((FAILURES + 1))
fi

xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/disk_detail.dat?eos.app=${DETAIL_APP}" > /dev/null 2>&1 &
PID_DETAIL=$!

sleep 5
FS_JSON_RESULT=$(eos io shaping ls --window 5 --fs --json)
ALL_JSON_RESULT=$(eos io shaping ls --window 5 --all --json)
APP_JSON_RESULT=$(eos io shaping ls --window 5 --json)

kill -9 $PID_DETAIL 2>/dev/null; wait $PID_DETAIL 2>/dev/null || true
eos io shaping config set --detail aggregate
sleep 2

if echo "$FS_JSON_RESULT" | jq -e '.[] | select(.type == "fs" and (.node_id | type == "string" and length > 0) and (.fsid > 0) and (.write_rate_bps > 0))' > /dev/null; then
  FS_ID=$(echo "$FS_JSON_RESULT" | jq -r '.[] | select(.type == "fs" and (.node_id | type == "string" and length > 0) and (.fsid > 0) and (.write_rate_bps > 0)) | "\(.node_id) fsid=\(.fsid)"' | head -n1)
  echo "✅ Success: Filesystem-level traffic detected in filesystem detail mode ($FS_ID)."
else
  echo "❌ Error: Filesystem-level traffic missing in filesystem detail mode."
  echo "Debug Info: $FS_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

if echo "$ALL_JSON_RESULT" | jq -e --arg app "$DETAIL_APP" '.[] | select(.type == "all" and (.node_id | type == "string" and length > 0) and (.fsid > 0) and (.app == $app) and (.uid | type == "number") and (.gid | type == "number") and (.write_rate_bps > 0))' > /dev/null; then
  ALL_ID=$(echo "$ALL_JSON_RESULT" | jq -r --arg app "$DETAIL_APP" '.[] | select(.type == "all" and (.node_id | type == "string" and length > 0) and (.fsid > 0) and (.app == $app) and (.write_rate_bps > 0)) | "\(.node_id) fsid=\(.fsid) app=\(.app) uid=\(.uid) gid=\(.gid)"' | head -n1)
  echo "✅ Success: Full tag traffic detected in filesystem detail mode ($ALL_ID)."
else
  echo "❌ Error: Full tag traffic missing in filesystem detail mode."
  echo "Debug Info: $ALL_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

AGGREGATE_APP="aggregate-all-test-app"
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/aggregate_all.dat?eos.app=${AGGREGATE_APP}" > /dev/null 2>&1 &
PID_AGGREGATE=$!

sleep 5
AGGREGATE_FS_JSON_RESULT=$(eos io shaping ls --window 5 --fs --json)
AGGREGATE_ALL_JSON_RESULT=$(eos io shaping ls --window 5 --all --json)

kill -9 $PID_AGGREGATE 2>/dev/null; wait $PID_AGGREGATE 2>/dev/null || true
eos io shaping config set --detail aggregate
sleep 2

if echo "$AGGREGATE_FS_JSON_RESULT" | jq -e 'length == 0' > /dev/null && \
   echo "$AGGREGATE_ALL_JSON_RESULT" | jq -e 'length > 0 and all(.[]; .type == "all" and .node_id == "<unknown>" and .fsid == 0)' > /dev/null && \
   echo "$AGGREGATE_ALL_JSON_RESULT" | jq -e --arg app "$AGGREGATE_APP" '.[] | select(.app == $app and (.uid | type == "number") and (.gid | type == "number") and (.write_rate_bps > 0))' > /dev/null; then
  echo "✅ Success: Aggregate detail mode hides --fs and exposes --all with sentinel node/fs values."
else
  echo "❌ Error: Aggregate detail mode did not return expected --fs/--all output."
  echo "Debug Info (--fs): $AGGREGATE_FS_JSON_RESULT"
  echo "Debug Info (--all): $AGGREGATE_ALL_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

if echo "$APP_JSON_RESULT" | jq -e --arg app "$DETAIL_APP" '.[] | select(.id == $app) | (.write_rate_bps > 0)' > /dev/null; then
  echo "✅ Success: App-level reporting still works in filesystem detail mode."
else
  echo "❌ Error: App-level reporting missing in filesystem detail mode."
  echo "Debug Info: $APP_JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: App Throttling Enforcement
# ---------------------------------------------------------
THROTTLE_APP="throttle-test-app"
echo ""
echo "--- Testing App Throttling ---"

echo "Priming feedback loop..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/prime.dat?eos.app=${THROTTLE_APP}" > /dev/null 2>&1

echo "Applying 1 MB/s write limit..."
eos io shaping policy set --app ${THROTTLE_APP} --limit-write 1M
sleep 3

echo "Starting throttled background transfer..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/test.dat?eos.app=${THROTTLE_APP}" > /dev/null 2>&1 &
PID=$!

echo "Waiting up to 32 seconds for strict EMA stabilization..."
APP_THROTTLED=0
if wait_for_rate_in_range "$THROTTLE_APP" write_rate_bps "$LOWER_BOUND" "$UPPER_BOUND"; then
  APP_THROTTLED=1
fi
kill -9 $PID 2>/dev/null; wait $PID 2>/dev/null || true
eos io shaping policy rm --app ${THROTTLE_APP}

if [[ $APP_THROTTLED -eq 1 ]]; then
  echo "✅ Success: App throttled properly ($RATE bps)."
else
  echo "❌ Error: Expected ~1MB/s, got $RATE bps."
  echo "Debug Info: $JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

# ---------------------------------------------------------
# Test: UID Throttling Enforcement
# ---------------------------------------------------------
TEST_UID="19999"
echo ""
echo "--- Testing UID Throttling ---"

echo "Priming feedback loop..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/uid_prime.dat?eos.ruid=${TEST_UID}" > /dev/null 2>&1

eos io shaping policy set --uid ${TEST_UID} --limit-write 1M
sleep 3

xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/uid_test.dat?eos.ruid=${TEST_UID}" > /dev/null 2>&1 &
PID=$!

echo "Waiting 22 seconds for strict EMA stabilization..."
sleep 22
JSON_RESULT=$(eos io shaping ls --window 5 --users --json)
kill -9 $PID 2>/dev/null; wait $PID 2>/dev/null || true
eos io shaping policy rm --uid ${TEST_UID}

if echo "$JSON_RESULT" | jq -e --argjson l "$LOWER_BOUND" --argjson u "$UPPER_BOUND" '.[] | select(.id == "19999") | (.write_rate_bps > $l) and (.write_rate_bps < $u)' > /dev/null; then
  echo "✅ Success: UID throttled properly."
else
  RATE=$(echo "$JSON_RESULT" | jq -r '.[] | select(.id == "19999") | .write_rate_bps // 0')
  echo "❌ Error: Expected ~1MB/s, got $RATE bps."
  echo "Debug Info: $JSON_RESULT"
  FAILURES=$((FAILURES + 1))
fi

