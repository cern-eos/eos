echo ""
echo "--- Testing Policy Toggle ---"

eos io shaping policy set --app ${TOGGLE_APP} --limit-write 1M
eos io shaping policy set --app ${TOGGLE_APP} --disable
sleep 3

START_MS=$(date +%s%3N)
xrdcp -f ${TEST_FILE_10MB} "${DEST_URL}/toggle_disabled.dat?eos.app=${TOGGLE_APP}" > /dev/null
END_MS=$(date +%s%3N)
echo "Transfer with disabled policy took $((END_MS - START_MS)) ms."

eos io shaping policy set --app ${TOGGLE_APP} --enable
echo "Priming feedback loop..."
xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/toggle_prime.dat?eos.app=${TOGGLE_APP}" > /dev/null 2>&1
sleep 3

xrdcp -f ${TEST_FILE_200MB} "${DEST_URL}/toggle_test.dat?eos.app=${TOGGLE_APP}" > /dev/null 2>&1 &
PID=$!

