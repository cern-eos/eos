#!/bin/bash

# Usage: eos-lru-test <eos_test_dir> <mgm_hostname>
# Example: eos-lru-test /eos/dev/test/lru_test_dir localhost

prefix=$1
host=${2-"localhost"}
url=root://$host
EOS_LRU_DIR=$prefix
watermarkLruDir="$EOS_LRU_DIR/watermarkLruDir"

cleanup() {
  eos quota rmnode --really-want "$watermarkLruDir/"
  eos rm -rF --no-confirmation "$EOS_LRU_DIR/"
}

assert_eq() {
  if [[ "$1" != "$2" ]];
  then
    echo "error: $3, expected value is $1 but received $2"
    exit 1
  fi
}

cleanup

# Prepare the instance
eos convert clear
eos convert config set status=on
eos space config default space.lru=on
eos space config default space.lru.interval=5

# --- Test the wildcard '*' as an expression for expiration ---
wildcardLruDir="$EOS_LRU_DIR/wildcardLruDir"
eos mkdir -p "$wildcardLruDir"
# Use the pure wildcard to match everything older than 5s
eos attr set 'sys.lru.expire.match=*:5s' "$wildcardLruDir"
eos touch "$wildcardLruDir/file1"
eos touch "$wildcardLruDir/file2"
eos touch "$wildcardLruDir/random_name"
assert_eq 3 "$(eos ls "$wildcardLruDir" | wc -l)" "wildcard test: files should exist initially"

sleep 10
# Everything should be gone if '*' is working
assert_eq 0 "$(eos ls "$wildcardLruDir" | wc -l)" "wildcard test: '*' expression failed to match and expire files"

# --- Test the LRU expire empty directory ---
eos mkdir -p "$EOS_LRU_DIR/" && eos touch "$EOS_LRU_DIR/file.touched"
eos attr set sys.lru.expire.empty=5 "$EOS_LRU_DIR/"
emptyDir="$EOS_LRU_DIR/empty_dir"
eos mkdir -p "$emptyDir"
sleep 10
assert_eq 0 "$(eos ls "$EOS_LRU_DIR" | grep -c 'empty_dir')" "empty_dir test: $emptyDir should be removed"

# --- Test match with prefix ---
accessTimeLruDir="$EOS_LRU_DIR/accessTimeLruDir"
eos mkdir -p "$accessTimeLruDir"
eos attr set 'sys.lru.expire.match=touched*:5s' "$accessTimeLruDir"
seq 1 100 | xargs -P 30 -I{} eos touch "$accessTimeLruDir/touched{}"
eos touch "$accessTimeLruDir/should_not_be_deleted"
sleep 10
assert_eq 1 "$(eos ls "$accessTimeLruDir" | grep -c 'should_not_be_deleted')" "prefix match test failed"

# --- Test size-based match with wildcard ---
sizeLruDir="$EOS_LRU_DIR/sizeLruDir"
eos mkdir -p "$sizeLruDir"
eos attr set 'sys.lru.expire.match=*:5s:<1M' "$sizeLruDir"
eos touch "$sizeLruDir/small_file"
sleep 10
assert_eq 0 "$(eos ls "$sizeLruDir" | wc -l)" "wildcard size-based LRU test: '*' with size constraint failed"

# --- Test the conversion LRU with wildcard ---
convertLruDir="$EOS_LRU_DIR/convertLruDir"
eos mkdir -p "$convertLruDir"
oneKBFile="/tmp/1KB"
threeKBFile="/tmp/3KB"
head -c 1k < /dev/urandom > "$oneKBFile"
head -c 3k < /dev/urandom > "$threeKBFile"
eos attr set 'sys.conversion.*=20640542' "$convertLruDir"

# Explicitly test the wildcard with size-based match for conversion LRU
eos attr set 'sys.lru.convert.match=*:4s:>2k' "$convertLruDir"

seq 1 50 | xargs -I{} -P 30 eos cp $oneKBFile "$url/$convertLruDir/1KB{}"
seq 1 50 | xargs -I{} -P 30 eos cp $threeKBFile "$url/$convertLruDir/3KB{}"

TARGET_VALUE=50 # Only the 50 files > 2k should be queued
TIMEOUT=25
INTERVAL=1
ELAPSED=0
SUCCESS=false

while (( $(echo "$ELAPSED < $TIMEOUT" | bc -l) )); do
    CURRENT_COUNT=$(eos convert list | grep -c '#')
    if [ "$CURRENT_COUNT" -eq "$TARGET_VALUE" ]; then
        SUCCESS=true
        break
    fi
    sleep $INTERVAL
    ELAPSED=$(echo "$ELAPSED + $INTERVAL" | bc -l)
done

if [ "$SUCCESS" = false ]; then
    echo "Error: convert LRU test: wildcard '*' in conversion failed (count: $CURRENT_COUNT)"
    exit 1
fi

# --- Test watermark ---
watermarkLruDir="$EOS_LRU_DIR/watermarkLruDir"
eos mkdir -p "$watermarkLruDir"
eos quota set -p "$watermarkLruDir" -v 11G -i 1M -g 99
eos attr set 'sys.lru.lowwatermark=1' "$watermarkLruDir"
eos attr set 'sys.lru.highwatermark=2' "$watermarkLruDir"
head -c 250M < /dev/urandom > /tmp/watermark_file
eos cp /tmp/watermark_file "$url/$watermarkLruDir/will-be-deleted"
sleep 10
assert_eq 0 "$(eos ls "$watermarkLruDir" | grep -c 'will-be-deleted')" "watermark test failed"

cleanup
echo "ALL LRU TESTS PASSED"
exit 0
